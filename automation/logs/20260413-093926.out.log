ream ends.\\n101:NAVIGATION_APPS = {\\n151:    NAVIGATION = \\\"NAVIGATION\\\"\\n166:    \\\"\\\"\\\"Send a command to mpv via IPC socket. Returns True on success.\\\"\\\"\\\"\\n180:    \\\"\\\"\\\"Get a property from mpv via IPC. Returns value or None.\\\"\\\"\\\"\\n225:    \\\"\\\"\\\"Return all active MPRIS player bus names.\\\"\\\"\\\"\\n288:    \\\"\\\"\\\"Send an MPRIS command via dbus-send. Returns True on success.\\\"\\\"\\\"\\n471:    if state_app and (state_app in NAVIGATION_APPS or state_app in LAUNCHER_APPS):\\n492:    has_nav_app = bool(app_set & NAVIGATION_APPS)\\n497:        return Mode.NAVIGATION\\n499:        return Mode.NAVIGATION\\n557:        ecodes.KEY_ENTER: \\\"Return\\\", ecodes.KEY_ESC: \\\"Escape\\\",\\n589:                ecodes.KEY_ENTER, ecodes.KEY_ESC, ecodes.KEY_BACKSPACE, ecodes.KEY_SPACE,\\n865:        self._jmp_foreground = False\\n949:        should_grab = (self.mode != Mode.GAMEPAD and not self._jmp_foreground)\\n1082:            self.mode = Mode.NAVIGATION if self._moonlight_foreground else detect_mode(apps)\\n1101:        self._jmp_foreground = bool(app_set & JELLYFIN_APPS)\\n1109:            # Stream ended — return to NAVIGATION (Moonlight UI) or LAUNCHER\\n1111:                new_mode = Mode.NAVIGATION\\n1116:        if self.media_mode_active and new_mode == Mode.NAVIGATION:\\n1155:        self._jmp_foreground = False\\n1279:        # ── LAUNCHER mode: A button -> Enter for flex-launcher selection ──\\n1282:                self.vinput.key_tap(ecodes.KEY_ENTER)\\n1283:            elif code == ecodes.BTN_SOUTH:  # B (Nintendo) -> Escape\\n1308:            elif code == ecodes.BTN_SOUTH:  # B (Nintendo) -> exit media mode\\n1311:                self.mode = Mode.NAVIGATION\\n1319:        # ── NAVIGATION mode buttons ──\\n1320:        if self.mode == Mode.NAVIGATION:\\n1323:                if self._moonlight_foreground or self._jmp_foreground:\\n1324:                    self.vinput.key_tap(ecodes.KEY_ENTER)\\n1329:                 