\n            }\n            open-settings() => {\n                AppBridge.navigate(\"settings\", \"\");\n            }\n            open-library(id) => {\n                AppBridge.navigate(\"library\", id);\n            }\n        }\n\n        if AppBridge.current-screen == \"detail\" : DetailScreen {\n            width: 100%;\n            height: 100%;\n            item: AppBridge.detail-item;\n            related-items: AppBridge.detail-related;\n            seasons: AppBridge.detail-seasons;\n            episodes: AppBridge.detail-episodes;\n            genres: AppBridge.genres;\n            cast-members: AppBridge.cast-members;\n            play-item(item-id) => {\n                AppBridge.play-item(item-id);\n            }\n            navigate(screen, param) => {\n                AppBridge.navigate(screen, param);\n            }\n            toggle-favorite(item-id) => {\n                AppBridge.toggle-favorite(item-id);\n            }\n            mark-played(item-id) => {\n                AppBridge.mark-played(item-id);\n            }\n            mark-unplayed(item-id) => {\n                AppBridge.mark-unplayed(item-id);\n            }\n            request-seasons(series-id) => {\n                AppBridge.request-seasons(series-id);\n            }\n            request-episodes(series-id, season-id) => {\n                AppBridge.request-episodes(series-id, season-id);\n            }\n            genre-selected(name) => {\n                AppBridge.genre-selected(name);\n            }\n            person-selected(id) => {\n                AppBridge.person-selected(id);\n            }\n        }\n\n        if AppBridge.current-screen == \"search\" : SearchScreen {\n            width: 100%;\n            height: 100%;\n            results: AppBridge.search-results;\n            search(query) => {\n                AppBridge.request-search(query);\n            }\n            select-result(id) => {\n                AppBridge.navigate(\"detail\", id);\n            }\n            go-back() => {\n                AppBridge.go-back();\n            }\n        }\n\n        if AppBridge.current-screen == \"library\" : LibraryScreen {\n            width: 100%;\n            height: 100%;\n            items: AppBridge.library-items;\n            title: AppBridge.library-title;\n            item-selected(id) => {\n                AppBridge.navigate(\"detail\", id);\n            }\n            sort-changed(sort) => {\n                AppBridge.request-library(\"\", sort, \"\");\n            }\n            filter-changed(filter) => {\n                AppBridge.request-library(\"\", \"\", filter);\n            }\n            go-back() => {\n                AppBridge.go-back();\n            }\n        }\n\n        if AppBridge.current-screen == \"settings\" : SettingsScreen {\n            width: 100%;\n            height: 100%;\n            username: AppBridge.current-user.name;\n            media-player: AppBridge.media-player;\n            logout() => {\n                AppBridge.logout();\n            }\n            toggle-media-player() => {\n                AppBridge.toggle-media-player();\n            }\n            go-back() => {\n                AppBridge.go-back();\n            }\n        }\n\n        // Player overlay - sits on top of content screens when playing\n        if AppBridge.current-screen == \"player\" : PlayerOverlay {\n            width: 100%;\n            height: 100%;\n            state: AppBridge.player-state;\n            play-pause() => {\n                AppBridge.play-pause();\n            }\n            seek(position-ms) => {\n                AppBridge.seek(position-ms);\n            }\n            seek-relative(offset-ms) => {\n                AppBridge.seek(AppBridge.player-state.position-ms + offset-ms);\n            }\n            next-track() => {\n                AppBridge.next-track();\n            }\n            prev-track() => {\n                AppBridge.prev-track();\n            }\n            set-audio(index) => {\n                AppBridge.set-audio-track(index);\n            }\n            set-subtitle(index) => {\n                AppBridge.set-subtitle-track(index);\n            }\n            set-volume(level) => {\n                AppBridge.set-volume(level);\n            }\n","exit_code":0,"status":"completed"}}
