{"type":"item.completed","item":{"id":"item_40","type":"command_execution","command":"/bin/zsh -lc \"cd /Users/danielmatthews-ferrero/Documents/local-codebases/jellyfin-pi && sed -n '1,300p' ui/home.slint\"","aggregated_output":"// Jellyfin Pi TV App - Home Screen Component\n// Main browse screen with horizontal content rows (Jellyfin Android TV layout)\n\nimport { Theme, MediaItem, ContentRowData, UserInfo } from \"theme.slint\";\nimport { MediaCard } from \"card.slint\";\nimport { ContentRow } from \"content-row.slint\";\n\nexport component HomeScreen inherits Rectangle {\n    width: 100%;\n    height: 100%;\n    background: transparent;\n\n    // -- Public API -----------------------------------------------------------\n\n    in property <[ContentRowData]> rows: [];\n    in property <UserInfo> current-user;\n    in property <string> current-time: \"00:00\";\n\n    in-out property <int> focused-row: 0;\n    in-out property <int> focused-col: 0;\n\n    callback item-selected(/* item_id */ string);\n    callback item-play(/* item_id */ string);\n    callback open-search();\n    callback open-settings();\n    callback open-library(/* library_id */ string);\n\n\n    // -- Internal state -------------------------------------------------------\n\n    // Height of each content row (title + cards + spacing)\n    pure function row-block-height() -> length {\n        return Theme.row-height + Theme.font-body-large + Theme.spacing-sm + Theme.spacing-lg;\n    }\n\n    // Target scroll offset to keep focused row visible\n    pure function target-scroll-y() -> length {\n        // Scroll so focused row is near the top with some margin\n        return root.focused-row <= 0 ? 0px : -max(0px, root.focused-row * root.row-block-height() - root.row-block-height() / 2);\n    }\n\n    // -- Focus handling -------------------------------------------------------\n\n    focus-scope := FocusScope {\n        init => { self.focus(); }\n        width: 100%;\n        height: 100%;\n\n        key-pressed(event) => {\n            if (event.text == Key.UpArrow) {\n                if (root.focused-row > 0) {\n                    root.focused-row -= 1;\n                    if (root.focused-col >= root.rows[root.focused-row].items.length) {\n                        root.focused-col = max(0, root.rows[root.focused-row].items.length - 1);\n                    }\n                }\n                return accept;\n            }\n            if (event.text == Key.DownArrow) {\n                if (root.focused-row < root.rows.length - 1) {\n                    root.focused-row += 1;\n                    // Clamp col to new row's item count\n                    if (root.focused-col >= root.rows[root.focused-row].items.length) {\n                        root.focused-col = max(0, root.rows[root.focused-row].items.length - 1);\n                    }\n                }\n                return accept;\n            }\n            // Left/Right arrows navigate within the focused row\n            if (event.text == Key.RightArrow) {\n                if (root.focused-row >= 0 && root.focused-row < root.rows.length) {\n                    if (root.focused-col < root.rows[root.focused-row].items.length - 1) {\n                        root.focused-col += 1;\n                    }\n                }\n                return accept;\n            }\n            if (event.text == Key.LeftArrow) {\n                if (root.focused-col > 0) {\n                    root.focused-col -= 1;\n                }\n                return accept;\n            }\n            // Enter/Space → select item\n            if (event.text == Key.Return || event.text == \" \") {\n                if (root.focused-row >= 0 && root.focused-row < root.rows.length) {\n                    if (root.focused-col >= 0 && root.focused-col < root.rows[root.focused-row].items.length) {\n                        root.item-selected(root.rows[root.focused-row].items[root.focused-col].id);\n                    }\n                }\n                return accept;\n            }\n            // Y button / F2 → settings\n            if (event.text == \"y\" || event.text == \"Y\" || event.text == Key.F2) {\n                root.open-settings();\n                return accept;\n            }\n            // X button / F3 → search\n            if (event.text == \"x\" || event.text == \"X\" || event.text == Key.F3) {\n                root.open-search();\n                return accept;\n            }\n            return reject;\n        }\n    }\n\n    // -- Layout ---------------------------------------------------------------\n\n    VerticalLayout {\n        padding-left: Theme.overscan-h;\n        padding-right: Theme.overscan-h;\n        padding-top: Theme.overscan-v;\n        padding-bottom: Theme.overscan-v;\n\n        // == Top bar ==========================================================\n        top-bar := HorizontalLayout {\n            height: 48px;\n            alignment: end;\n            spacing: Theme.spacing-md;\n            padding-bottom: Theme.spacing-sm;\n\n            // Spacer to push items right\n            Rectangle { horizontal-stretch: 1; }\n\n            // Clock\n            Text {\n                text: root.current-time;\n                font-size: Theme.font-body-medium;\n                color: Theme.text-secondary;\n                vertical-alignment: center;\n            }\n\n            // Separator dot\n            Text {\n                text: \"\\u{2022}\";\n                font-size: Theme.font-body-medium;\n                color: Theme.text-tertiary;\n                vertical-alignment: center;\n            }\n\n            // User name\n            Text {\n                text: root.current-user.name;\n                font-size: Theme.font-body-medium;\n                color: Theme.text-secondary;\n                vertical-alignment: center;\n                font-weight: 600;\n            }\n\n            // User avatar\n            Rectangle {\n                width: 32px;\n                height: 32px;\n                border-radius: 16px;\n                background: Theme.surface-variant;\n                clip: true;\n\n                Image {\n                    width: 100%;\n                    height: 100%;\n                    source: root.current-user.avatar;\n                    image-fit: cover;\n                }\n\n                // Fallback initial when no avatar\n                Text {\n                    visible: root.current-user.name != \"\";\n                    text: root.current-user.name;\n                    font-size: Theme.font-body-small;\n                    color: Theme.text-secondary;\n                    horizontal-alignment: center;\n                    vertical-alignment: center;\n                }\n            }\n        }\n\n        // == Scrollable content rows ==========================================\n        Rectangle {\n            vertical-stretch: 1;\n            clip: true;\n\n            VerticalLayout {\n                y: root.target-scroll-y();\n                animate y {\n                    duration: Theme.transition-duration;\n                    easing: ease-in-out;\n                }\n                spacing: Theme.spacing-lg;\n\n                for row[index] in root.rows : ContentRow {\n                    title: row.title;\n                    items: row.items;\n                    is-landscape: row.row-type == \"landscape\";\n                    row-focused: index == root.focused-row;\n                    focused-index: root.focused-col;\n\n                    item-selected(id) => {\n                        root.item-selected(id);\n                    }\n                    item-play-requested(id) => {\n                        root.item-play(id);\n                    }\n                }\n            }\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
