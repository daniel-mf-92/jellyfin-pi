        ApiError::NotFound => write!(f, \"Not found\"),\n    31\t            ApiError::Server(msg) => write!(f, \"Server error: {msg}\"),\n    32\t        }\n    33\t    }\n    34\t}\n    35\t\n    36\timpl std::error::Error for ApiError {}\n    37\t\n    38\timpl From<reqwest::Error> for ApiError {\n    39\t    fn from(e: reqwest::Error) -> Self {\n    40\t        if e.status() == Some(reqwest::StatusCode::NOT_FOUND) {\n    41\t            ApiError::NotFound\n    42\t        } else if e.status() == Some(reqwest::StatusCode::UNAUTHORIZED) {\n    43\t            ApiError::Auth(\"Unauthorized\".into())\n    44\t        } else {\n    45\t            ApiError::Network(e)\n    46\t        }\n    47\t    }\n    48\t}\n    49\t\n    50\tpub type ApiResult<T> = Result<T, ApiError>;\n    51\t\n    52\t// ---------------------------------------------------------------------------\n    53\t// Client\n    54\t// ---------------------------------------------------------------------------\n    55\t\n    56\tpub struct JellyfinClient {\n    57\t    http: Client,\n    58\t    pub server_url: String,\n    59\t    pub access_token: Option<String>,\n    60\t    pub user_id: Option<String>,\n    61\t    device_id: String,\n    62\t    device_name: String,\n    63\t    client_name: String,\n    64\t    client_version: String,\n    65\t}\n    66\t\n    67\timpl JellyfinClient {\n    68\t    /// Create a new client from application config.\n    69\t    pub fn new(config: &AppConfig) -> Self {\n    70\t        let http = Client::builder()\n    71\t            .connect_timeout(Duration::from_secs(HTTP_CONNECT_TIMEOUT_SECS))\n    72\t            .timeout(Duration::from_secs(HTTP_REQUEST_TIMEOUT_SECS))\n    73\t            .build()\n    74\t            .unwrap_or_else(|_| Client::new());\n    75\t\n    76\t        Self {\n    77\t            http,\n    78\t            server_url: config.server.url.clone(),\n    79\t            access_token: None,\n    80\t            user_id: None,\n    81\t 