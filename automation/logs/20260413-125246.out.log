y\\\\\\\\\\\\\\\".into());\\\\\\\\n                        ui.global::<AppBridge>().set_is_loading(true);\\\\\\\\n                    });\\\\\\\\n                    if let Err(e) = load_library(\\\\\\\\n                        ui_weak.clone(),\\\\\\\\n                        client,\\\\\\\\n                        image_cache,\\\\\\\\n                        &library_id,\\\\\\\\n                        None,\\\\\\\\n                        None,\\\\\\\\n                    )\\\\\\\\n                    .await\\\\\\\\n                    {\\\\\\\\n                        error!(\\\\\\\\\\\\\\\"Failed to load library {}: {}\\\\\\\\\\\\\\\", library_id, e);\\\\\\\\n                        let _ = ui_weak.upgrade_in_event_loop(move |ui| {\\\\\\\\n                            ui.global::<AppBridge>()\\\\\\\\n                                .set_error_message(format!(\\\\\\\\\\\\\\\"Failed to load library: {}\\\\\\\\\\\\\\\", e).into());\\\\\\\\n                            ui.global::<AppBridge>().set_is_loading(false);\\\\\\\\n                        });\\\\\\\\n                    }\\\\\\\\n\\\\\\\",\\\\\\\"exit_code\\\\\\\":0,\\\\\\\"status\\\\\\\":\\\\\\\"completed\\\\\\\"}}\\\\nautomation/logs/20260413-085135.out.log:55:{\\\\\\\"type\\\\\\\":\\\\\\\"item.started\\\\\\\",\\\\\\\"item\\\\\\\":{\\\\\\\"id\\\\\\\":\\\\\\\"item_28\\\\\\\",\\\\\\\"type\\\\\\\":\\\\\\\"command_execution\\\\\\\",\\\\\\\"command\\\\\\\":\\\\\\\"/bin/zsh -lc \\\\\\\\\\\\\\\"cd /Users/danielmatthews-ferrero/Documents/local-codebases/jellyfin-pi && rg -n \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"async fn load_item_detail|set_is_loading\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\(false\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\)|load_home_data\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\(|load_library\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\(|on_login|select-user|on_login|on_request_item_detail\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" src/main.rs | head -n 200\\\\\\\\\\\\\\\"\\\\\\\",\\\\\\\"aggregated_output\\\\\\\":\\\\\\\"\\\\\\\",\\\\\\\"exit_code\\\\\\\"