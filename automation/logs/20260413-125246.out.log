= self\n   268\t            .user_id\n   269\t            .as_deref()\n   270\t            .ok_or_else(|| ApiError::Auth(\"Not authenticated\".into()))?;\n   271\t\n   272\t        let url = format!(\"{}/Users/{}/Items/Latest\", self.server_url, user_id);\n   273\t        let resp = self\n   274\t            .http\n   275\t            .get(&url)\n   276\t            .header(\"Authorization\", self.auth_header())\n   277\t            .query(&[\n   278\t                (\"ParentId\", parent_id),\n   279\t                (\"Limit\", &limit.to_string()),\n   280\t                (\"Fields\", ITEM_FIELDS),\n   281\t            ])\n   282\t            .send()\n   283\t            .await?;\n   284\t        let resp = self.check_response(resp).await?;\n   285\t        // Latest endpoint returns a plain array, not a QueryResult wrapper\n   286\t        Ok(resp.json().await?)\n   287\t    }\n   288\t\n   289\t    // -----------------------------------------------------------------------\n   290\t    // Items / browsing\n   291\t    // -----------------------------------------------------------------------\n   292\t\n   293\t    /// GET /Items — generic item query with many optional filters.\n   294\t    pub async fn get_items(\n   295\t        &self,\n   296\t        parent_id: Option<&str>,\n   297\t        item_types: Option<&str>,\n   298\t        sort_by: Option<&str>,\n   299\t        sort_order: Option<&str>,\n   300\t        start_index: i32,\n   301\t        limit: i32,\n   302\t        filters: Option<&str>,\n   303\t    ) -> ApiResult<QueryResult> {\n   304\t        let user_id = self\n   305\t            .user_id\n   306\t            .as_deref()\n   307\t            .ok_or_else(|| ApiError::Auth(\"Not authenticated\".into()))?;\n   308\t\n   309\t        let url = format!(\"{}/Users/{}/Items\", self.server_url, user_id);\n   310\t\n   311\t        let mut params: Vec<(&str, String)> = vec![\n   312\t            (\"StartIndex\", start_index.to_string()),\n   313\t  