{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/bin/zsh -lc \"cd /Users/danielmatthews-ferrero/Documents/local-codebases/jellyfin-pi && nl -ba src/api/images.rs | sed -n '1,120p'\"","aggregated_output":"     1\tuse std::collections::HashMap;\n     2\tuse std::hash::{Hash, Hasher};\n     3\tuse std::io::Cursor;\n     4\tuse std::path::PathBuf;\n     5\tuse std::sync::Arc;\n     6\tuse std::time::Duration;\n     7\t\n     8\tuse image::imageops::FilterType;\n     9\tuse image::GenericImageView;\n    10\tuse log::{debug, error, info, warn};\n    11\tuse slint::Image as SlintImage;\n    12\tuse slint::Rgba8Pixel;\n    13\tuse slint::SharedPixelBuffer;\n    14\tuse tokio::sync::RwLock;\n    15\t\n    16\t/// Maximum number of images kept in memory before eviction kicks in.\n    17\tconst DEFAULT_MAX_MEMORY_ITEMS: usize = 10;\n    18\t\n    19\t/// Hard cap for decoded image dimensions kept in memory.\n    20\t/// This protects the UI process from large backdrops/posters that ignore\n    21\t/// Jellyfin's `maxHeight`/`maxWidth` hint parameters.\n    22\tconst MAX_DECODED_IMAGE_DIMENSION: u32 = 640;\n    23\t\n    24\t/// Reject source images above this dimension before full decode to avoid\n    25\t/// extreme temporary allocations during decode.\n    26\tconst MAX_SOURCE_IMAGE_DIMENSION: u32 = 3000;\n    27\tconst MAX_SOURCE_IMAGE_PIXELS: u64 = 2_500_000;\n    28\t\n    29\t/// Maximum number of concurrent image downloads during preload.\n    30\tconst MAX_CONCURRENT_DOWNLOADS: usize = 10;\n    31\tconst IMAGE_CONNECT_TIMEOUT_SECS: u64 = 5;\n    32\tconst IMAGE_REQUEST_TIMEOUT_SECS: u64 = 15;\n    33\tconst MAX_IMAGE_DOWNLOAD_BYTES: usize = 4 * 1024 * 1024;\n    34\t\n    35\t/// Thread-safe, async image cache that stores decoded Slint images in memory\n    36\t/// and raw image bytes on disk for fast reloading across sessions.\n    37\tpub struct ImageCache {\n    38\t    cache_dir: PathBuf,\n    39\t    memory_cache: Arc<RwLock<HashMap<String, SlintImage>>>,\n    40\t    http: reqwest::Client,\n    41\t    max_memory_items: usize,\n    42\t}\n    43\t\n    44\timpl ImageCache {\n    45\t    /// Create a new `ImageCache`.\n    46\t    ///\n    47\t    /// The on-disk cache lives under the platform-appropriate cache directory\n    48\t    /// provided by `directories::ProjectDirs` (e.g. `~/.cache/jellyfin-pi/images`\n    49\t    /// on Linux, `~/Library/Caches/org.jellyfin.jellyfin-pi/images` on macOS).\n    50\t    /// The directory is created if it does not already exist.\n    51\t    pub fn new(http: reqwest::Client) -> Self {\n    52\t        let cache_dir = directories::ProjectDirs::from(\"org\", \"jellyfin\", \"jellyfin-pi\")\n    53\t            .map(|dirs| dirs.cache_dir().join(\"images\"))\n    54\t            .unwrap_or_else(|| {\n    55\t                warn!(\"Could not determine platform cache directory, falling back to /tmp\");\n    56\t                PathBuf::from(\"/tmp/jellyfin-pi-images\")\n    57\t            });\n    58\t\n    59\t        if let Err(e) = std::fs::create_dir_all(&cache_dir) {\n    60\t            error!(\"Failed to create image cache directory {:?}: {}\", cache_dir, e);\n    61\t        } else {\n    62\t            info!(\"Image cache directory: {:?}\", cache_dir);\n    63\t        }\n    64\t\n    65\t        let http = reqwest::Client::builder()\n    66\t            .connect_timeout(Duration::from_secs(IMAGE_CONNECT_TIMEOUT_SECS))\n    67\t            .timeout(Duration::from_secs(IMAGE_REQUEST_TIMEOUT_SECS))\n    68\t            .build()\n    69\t            .unwrap_or(http);\n    70\t\n    71\t        Self {\n    72\t            cache_dir,\n    73\t            memory_cache: Arc::new(RwLock::new(HashMap::new())),\n    74\t            http,\n    75\t            max_memory_items: DEFAULT_MAX_MEMORY_ITEMS,\n    76\t        }\n    77\t    }\n    78\t\n    79\t    /// Load an image from cache (memory -> disk -> network), returning a Slint\n    80\t    /// `Image` ready for display. Returns `None` if the image could not be\n    81\t    /// obtained from any source.\n    82\t    pub async fn load_image(&self, url: &str) -> Option<SlintImage> {\n    83\t        // 1. Fast path: in-memory cache.\n    84\t        {\n    85\t            let cache = self.memory_cache.read().await;\n    86\t            if let Some(img) = cache.get(url) {\n    87\t                debug!(\"Image cache hit (memory): {}\", url);\n    88\t                return Some(img.clone());\n    89\t            }\n    90\t        }\n    91\t\n    92\t        // 2. Disk cache.\n    93\t        let disk_path = self.url_to_cache_path(url);\n    94\t        if disk_path.exists() {\n    95\t            debug!(\"Image cache hit (disk): {}\", url);\n    96\t            if let Some(img) = self.load_from_disk(&disk_path).await {\n    97\t                // Promote to memory cache.\n    98\t                self.insert_memory_cache(url, &img).await;\n    99\t                return Some(img);\n   100\t            } else {\n   101\t                warn!(\"Disk-cached image corrupt, will re-download: {}\", url);\n   102\t                let _ = tokio::fs::remove_file(&disk_path).await;\n   103\t            }\n   104\t        }\n   105\t\n   106\t        // 3. Download from network.\n   107\t        debug!(\"Image cache miss, downloading: {}\", url);\n   108\t        let bytes = self.download_bytes(url).await?;\n   109\t\n   110\t        // Save raw bytes to disk (before decode, so we store the original).\n   111\t        if let Err(e) = self.save_to_disk(&disk_path, &bytes).await {\n   112\t            warn!(\"Failed to persist image to disk cache: {}\", e);\n   113\t        }\n   114\t\n   115\t        // Decode into a Slint image.\n   116\t        let img = Self::decode_to_slint(&bytes)?;\n   117\t        self.insert_memory_cache(url, &img).await;\n   118\t        Some(img)\n   119\t    }\n   120\t\n","exit_code":0,"status":"completed"}}
