.len());\n  2728\t    Ok(())\n  2729\t}\n  2730\t\n  2731\t// =============================================================================\n  2732\t// Player Event Handling\n  2733\t// =============================================================================\n  2734\t\n  2735\t/// Handle VLC player events and relay them to the UI + Jellyfin server.\n  2736\tasync fn handle_player_events(\n  2737\t    ui_weak: slint::Weak<AppWindow>,\n  2738\t    client: Arc<RwLock<JellyfinClient>>,\n  2739\t    state: Arc<StateManager>,\n  2740\t    player: Arc<Mutex<Option<PlayerWrapper>>>,\n  2741\t    daemon_player_tx: mpsc::UnboundedSender<PlayerEvent>,\n  2742\t    tracker: Arc<PlaybackTracker>,\n  2743\t    segments: Arc<Mutex<SegmentManager>>,\n  2744\t    playback_controls: Arc<Mutex<PlaybackControls>>,\n  2745\t    queue: Arc<Mutex<PlaybackQueue>>,\n  2746\t) {\n  2747\t    // Take the event receiver from the player\n  2748\t    let mut event_rx = {\n  2749\t        let mut p = player.lock().await;\n  2750\t        match p.as_mut() {\n  2751\t            Some(vlc) => match vlc.take_event_receiver() {\n  2752\t                Some(rx) => rx,\n  2753\t                None => {\n  2754\t                    debug!(\"Player event receiver already taken\");\n  2755\t                    return;\n  2756\t                }\n  2757\t            },\n  2758\t            None => return,\n  2759\t        }\n  2760\t    };\n  2761\t\n  2762\t    // Also start the VLC event loop to generate events.\n  2763\t    // We check if the player exists, then spawn a task that briefly locks\n  2764\t    // the mutex only to get what it needs, releasing it before the long-running loop.\n  2765\t    {\n  2766\t        let has_player = {\n  2767\t            let p = player.lock().await;\n  2768\t            p.is_some()\n  2769\t        };\n  2770\t        if has_player {\n  2771\t            // Note: run_event_loop holds the Mutex for its duration.\n  2772\t            // This is acceptable becaus