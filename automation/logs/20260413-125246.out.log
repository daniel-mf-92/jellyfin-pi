g-progress;\\n            bar-visible: true;\\n            bar-clicked() => {\\n                AppBridge.now-playing-clicked();\\n            }\\n        }\\n\\n        // Loading overlay - visible on top of all screens when loading\\n        if AppBridge.is-loading : Rectangle {\\n            width: 100%;\\n            height: 100%;\\n            background: Theme.background.with-alpha(0.7);\\n\\n            LoadingSpinner {\\n                width: 80px;\\n                height: 80px;\\n                x: (parent.width - self.width) / 2;\\n                y: (parent.height - self.height) / 2;\\n                active: true;\\n            }\\n\\n            // Escape must ALWAYS work, even during loading\\n            FocusScope {\\n                width: 100%;\\n                height: 100%;\\n                key-pressed(event) => {\\n                    if (event.text == Key.Escape) {\\n                        AppBridge.is-loading = false;\\n                        AppBridge.go-back();\\n                        return accept;\\n                    }\\n                    return reject;\\n                }\\n            }\\n        }\\n\\n        // Error message overlay\\n        if AppBridge.error-message != \\\"\\\" : Rectangle {\\n            width: 100%;\\n            height: 100%;\\n            background: Theme.background.with-alpha(0.85);\\n\\n            Rectangle {\\n                width: 600px;\\n                height: 200px;\\n                x: (parent.width - self.width) / 2;\\n                y: (parent.height - self.height) / 2;\\n                background: Theme.surface;\\n                border-radius: 12px;\\n                border-width: 1px;\\n                border-color: Theme.error;\\n\\n                VerticalLayout {\\n                    alignment: center;\\n                    padding: 32px;\\n                    spacing: 16px;\\n\\n                    Text {\\n                        text: \\\"Error\\\";\\n                       