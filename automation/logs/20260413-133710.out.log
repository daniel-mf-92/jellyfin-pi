{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/bin/zsh -lc \"sed -n '140,220p' ui/app.slint\"","aggregated_output":"    in property <string> media-player: \"vlc\";\n    callback toggle-media-player();\n\n    // Trickplay\n    in property <image> trickplay-thumbnail;\n    in property <string> trickplay-timestamp;\n    in property <bool> trickplay-scrubbing;\n}\n\nexport component AppWindow inherits Window {\n    title: \"Jellyfin\";\n    background: Theme.background;\n    // Note: default-font-family and default-font-size set by system defaults\n    width: 1920px;\n    height: 1080px;\n\n    // Global key handler\n    FocusScope {\n        width: 100%;\n        height: 100%;\n        init => { self.focus(); }\n\n        key-pressed(event) => {\n            if (event.text == Key.Escape) {\n                if (AppBridge.is-loading) {\n                    AppBridge.is-loading = false;\n                }\n                AppBridge.go-back();\n                return accept;\n            }\n            // Home key navigates to home screen\n            if (event.text == Key.F1) {\n                AppBridge.navigate(\"home\", \"\");\n                return accept;\n            }\n            return reject;\n        }\n\n        // Screen layers - only one visible at a time based on current-screen\n\n        if AppBridge.current-screen == \"login\" : LoginScreen {\n            width: 100%;\n            height: 100%;\n            users: AppBridge.users;\n            select-user(id) => {\n                AppBridge.login(id, \"\");\n            }\n            submit-password(user-id, password) => {\n                AppBridge.login(user-id, password);\n            }\n        }\n\n        if AppBridge.current-screen == \"home\" : HomeScreen {\n            width: 100%;\n            height: 100%;\n            rows: AppBridge.home-rows;\n            current-user: AppBridge.current-user;\n            item-selected(id) => {\n                AppBridge.navigate(\"detail\", id);\n            }\n            item-play(id) => {\n                AppBridge.play-item(id);\n            }\n            open-search() => {\n                AppBridge.navigate(\"search\", \"\");\n            }\n            open-settings() => {\n                AppBridge.navigate(\"settings\", \"\");\n            }\n            open-library(id) => {\n                AppBridge.navigate(\"library\", id);\n            }\n        }\n\n        if AppBridge.current-screen == \"detail\" : DetailScreen {\n            width: 100%;\n            height: 100%;\n            item: AppBridge.detail-item;\n            related-items: AppBridge.detail-related;\n            seasons: AppBridge.detail-seasons;\n            episodes: AppBridge.detail-episodes;\n","exit_code":0,"status":"completed"}}
