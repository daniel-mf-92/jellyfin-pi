{"type":"item.completed","item":{"id":"item_44","type":"command_execution","command":"/bin/zsh -lc \"cd /Users/danielmatthews-ferrero/Documents/local-codebases/jellyfin-pi && nl -ba src/daemon/audio.rs | sed -n '1,240p'\"","aggregated_output":"     1\tuse std::sync::Arc;\n     2\tuse tokio::process::Command;\n     3\tuse tokio::sync::Mutex;\n     4\tuse tokio::time::Duration;\n     5\tuse log::{info, warn, debug};\n     6\t\n     7\tuse super::DaemonShared;\n     8\t\n     9\t/// Wayland environment vars needed for pactl/wpctl/systemctl --user.\n    10\tconst WAYLAND_DISPLAY: &str = \"wayland-0\";\n    11\tconst XDG_RUNTIME_DIR: &str = \"/run/user/1000\";\n    12\t\n    13\tpub struct AudioHealer {\n    14\t    shared: Arc<DaemonShared>,\n    15\t    interval_sec: u64,\n    16\t    hdmi_miss_streak: Mutex<u8>,\n    17\t}\n    18\t\n    19\timpl AudioHealer {\n    20\t    pub fn new(shared: Arc<DaemonShared>, interval_sec: u64) -> Self {\n    21\t        Self {\n    22\t            shared,\n    23\t            interval_sec,\n    24\t            hdmi_miss_streak: Mutex::new(0),\n    25\t        }\n    26\t    }\n    27\t\n    28\t    pub async fn run(self) {\n    29\t        // Wait for GUI to be ready\n    30\t        tokio::time::sleep(Duration::from_secs(30)).await;\n    31\t\n    32\t        let mut interval = tokio::time::interval(Duration::from_secs(self.interval_sec));\n    33\t        loop {\n    34\t            interval.tick().await;\n    35\t\n    36\t            // Only heal if labwc compositor is running\n    37\t            if !super::system::is_process_running(\"labwc\").await {\n    38\t                continue;\n    39\t            }\n    40\t\n    41\t            self.heal_pipewire().await;\n    42\t            self.heal_hdmi_sink().await;\n    43\t        }\n    44\t    }\n    45\t\n    46\t    /// Check PipeWire health via `pactl list sinks short` with 3s timeout.\n    47\t    /// Restart the audio stack if unresponsive.\n    48\t    async fn heal_pipewire(&self) {\n    49\t        let result = tokio::time::timeout(\n    50\t            Duration::from_secs(3),\n    51\t            self.run_wayland_cmd(\"pactl\", &[\"list\", \"sinks\", \"short\"]),\n    52\t        )\n    53\t        .await;\n    54\t\n    55\t        let sink_output = match result {\n    56\t            Ok(Ok(output)) if !output.is_empty() => output,\n    57\t            _ => {\n    58\t                // PipeWire not responding — attempt restart\n    59\t                warn!(\"PipeWire/pactl not responding, restarting audio stack...\");\n    60\t\n    61\t                let mut cb = self.shared.circuit_breaker.write().await;\n    62\t                if !cb.try_restart(\"pipewire\", None) {\n    63\t                    return;\n    64\t                }\n    65\t                drop(cb);\n    66\t\n    67\t                let _ = Command::new(\"systemctl\")\n    68\t                    .args([\"--user\", \"restart\", \"pipewire\", \"pipewire-pulse\", \"wireplumber\"])\n    69\t                    .env(\"XDG_RUNTIME_DIR\", XDG_RUNTIME_DIR)\n    70\t                    .env(\"DBUS_SESSION_BUS_ADDRESS\", format!(\"unix:path={}/bus\", XDG_RUNTIME_DIR))\n    71\t                    .output()\n    72\t                    .await;\n    73\t\n    74\t                tokio::time::sleep(Duration::from_secs(3)).await;\n    75\t\n    76\t                // Verify recovery\n    77\t                if let Ok(output) = self\n    78\t                    .run_wayland_cmd(\"pactl\", &[\"list\", \"sinks\", \"short\"])\n    79\t                    .await\n    80\t                {\n    81\t                    if !output.is_empty() {\n    82\t                        info!(\"Audio stack restored\");\n    83\t                    } else {\n    84\t                        warn!(\"Audio stack still broken after restart\");\n    85\t                    }\n    86\t                }\n    87\t                return;\n    88\t            }\n    89\t        };\n    90\t\n    91\t        // Ensure HDMI is default sink (not null/network)\n    92\t        if let Some(hdmi_sink) = sink_output.lines().find(|l| l.contains(\"hdmi\")) {\n    93\t            let sink_name = hdmi_sink.split_whitespace().nth(1).unwrap_or(\"\");\n    94\t            if !sink_name.is_empty() {\n    95\t                // Check current default\n    96\t                let current = self\n    97\t                    .run_wayland_cmd(\"pactl\", &[\"get-default-sink\"])\n    98\t                    .await\n    99\t                    .unwrap_or_default();\n   100\t                let current = current.trim();\n   101\t\n   102\t                if current != sink_name {\n   103\t                    let _ = self\n   104\t                        .run_wayland_cmd(\"pactl\", &[\"set-default-sink\", sink_name])\n   105\t                        .await;\n   106\t                    info!(\"Set default sink to HDMI: {} (was: {})\", sink_name, current);\n   107\t                }\n   108\t\n   109\t                // Ensure volume at 100%\n   110\t                let _ = self\n   111\t                    .run_wayland_cmd(\"pactl\", &[\"set-sink-volume\", sink_name, \"100%\"])\n   112\t                    .await;\n   113\t            }\n   114\t        } else {\n   115\t            debug!(\"No HDMI sink found in pactl output\");\n   116\t        }\n   117\t    }\n   118\t\n   119\t    /// Check WirePlumber HDMI sink via `wpctl status`.\n   120\t    async fn heal_hdmi_sink(&self) {\n   121\t        let status = match self.run_wayland_cmd(\"wpctl\", &[\"status\"]).await {\n   122\t            Ok(s) => s,\n   123\t            Err(_) => return,\n   124\t        };\n   125\t\n   126\t        // Find HDMI sink ID\n   127\t        let hdmi_id = status\n   128\t            .lines()\n   129\t            .find(|l| l.contains(\"Built-in Audio Digital Stereo (HDMI)\"))\n   130\t            .and_then(|l| {\n   131\t                l.trim()\n   132\t                    .trim_start_matches('*')\n   133\t                    .trim()\n   134\t                    .split_whitespace()\n   135\t                    .next()\n   136\t                    .and_then(|s| s.trim_end_matches('.').parse::<u32>().ok())\n   137\t            });\n   138\t\n   139\t        if let Some(id) = hdmi_id {\n   140\t            {\n   141\t                let mut miss_streak = self.hdmi_miss_streak.lock().await;\n   142\t                *miss_streak = 0;\n   143\t            }\n   144\t\n   145\t            // Check if it's the default (has * prefix)\n   146\t            let is_default = status\n   147\t                .lines()\n   148\t                .any(|l| l.contains(\"Built-in Audio Digital Stereo (HDMI)\") && l.trim().starts_with('*'));\n   149\t\n   150\t            if !is_default {\n   151\t                let _ = self\n   152\t                    .run_wayland_cmd(\"wpctl\", &[\"set-default\", &id.to_string()])\n   153\t                    .await;\n   154\t                info!(\"Reset WirePlumber default sink to HDMI (id: {})\", id);\n   155\t            }\n   156\t        } else {\n   157\t            let misses = {\n   158\t                let mut miss_streak = self.hdmi_miss_streak.lock().await;\n   159\t                *miss_streak = miss_streak.saturating_add(1);\n   160\t                *miss_streak\n   161\t            };\n   162\t\n   163\t            // Debounce transient PipeWire race conditions before restart.\n   164\t            if misses < 3 {\n   165\t                debug!(\"HDMI sink not visible yet (miss {}/3), deferring WirePlumber restart\", misses);\n   166\t                return;\n   167\t            }\n   168\t\n   169\t            // HDMI sink missing repeatedly — restart WirePlumber\n   170\t            let mut cb = self.shared.circuit_breaker.write().await;\n   171\t            if !cb.try_restart(\"wireplumber\", None) {\n   172\t                return;\n   173\t            }\n   174\t            drop(cb);\n   175\t\n   176\t            {\n   177\t                let mut miss_streak = self.hdmi_miss_streak.lock().await;\n   178\t                *miss_streak = 0;\n   179\t            }\n   180\t\n   181\t            warn!(\"HDMI sink missing, restarting WirePlumber...\");\n   182\t            let _ = Command::new(\"systemctl\")\n   183\t                .args([\"--user\", \"restart\", \"wireplumber\"])\n   184\t                .env(\"XDG_RUNTIME_DIR\", XDG_RUNTIME_DIR)\n   185\t                .env(\"DBUS_SESSION_BUS_ADDRESS\", format!(\"unix:path={}/bus\", XDG_RUNTIME_DIR))\n   186\t                .output()\n   187\t                .await;\n   188\t\n   189\t            tokio::time::sleep(Duration::from_secs(3)).await;\n   190\t            info!(\"WirePlumber restarted\");\n   191\t        }\n   192\t    }\n   193\t\n   194\t    /// Run a command with Wayland + XDG environment set.\n   195\t    async fn run_wayland_cmd(&self, program: &str, args: &[&str]) -> Result<String, std::io::Error> {\n   196\t        let output = Command::new(program)\n   197\t            .args(args)\n   198\t            .env(\"WAYLAND_DISPLAY\", WAYLAND_DISPLAY)\n   199\t            .env(\"XDG_RUNTIME_DIR\", XDG_RUNTIME_DIR)\n   200\t            .env(\"DBUS_SESSION_BUS_ADDRESS\", format!(\"unix:path={}/bus\", XDG_RUNTIME_DIR))\n   201\t            .output()\n   202\t            .await?;\n   203\t\n   204\t        Ok(String::from_utf8_lossy(&output.stdout).to_string())\n   205\t    }\n   206\t}\n","exit_code":0,"status":"completed"}}
