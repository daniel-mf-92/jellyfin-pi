rd) {\\n   553\\t                            root.show-password = true;\\n   554\\t                            root.password-input = \\\"\\\";\\n   555\\t                            root.focused-key = 0;\\n   556\\t                            root.focused-key-row = 0;\\n   557\\t                        } else {\\n   558\\t                            root.select-user(root.users[root.focused-user].id);\\n   559\\t                        }\\n   560\\t                    }\\n   561\\t                    return accept;\\n   562\\t                }\\n   563\\t            } else if (root.show-password) {\\n   564\\t                // --- Password / virtual keyboard mode ---\\n   565\\t\\n   566\\t                // Navigate keyboard: Right\\n   567\\t                if (event.text == Key.RightArrow) {\\n   568\\t                    if (root.focused-key < root.row-lengths[root.focused-key-row] - 1) {\\n   569\\t                        root.focused-key += 1;\\n   570\\t                    }\\n   571\\t                    return accept;\\n   572\\t                }\\n   573\\t                // Navigate keyboard: Left\\n   574\\t                if (event.text == Key.LeftArrow) {\\n   575\\t                    if (root.focused-key > 0) {\\n   576\\t                        root.focused-key -= 1;\\n   577\\t                    }\\n   578\\t                    return accept;\\n   579\\t                }\\n   580\\t                // Navigate keyboard: Down\\n   581\\t                if (event.text == Key.DownArrow) {\\n   582\\t                    if (root.focused-key-row < 4) {\\n   583\\t                        root.focused-key-row += 1;\\n   584\\t                        // Clamp column to new row length\\n   585\\t                        if (root.focused-key >= root.row-lengths[root.focused-key-row]) {\\n   586\\t                            root.focused-key = root.row-lengths[root.focused-key-row] - 1;\\n   587\\t                        }\\n   588\\t                    }\\n  