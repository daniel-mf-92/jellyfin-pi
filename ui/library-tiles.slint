// Jellyfin Pi TV App - Library Tiles Row Component
// Horizontal row of small library selector tiles (Movies, TV Shows, Music, etc.)
// Displayed at top of home screen, matching Jellyfin web client layout.

import { Theme } from "theme.slint";

export struct LibraryTile {
    id: string,
    name: string,
    collection-type: string,
}

export component LibraryTilesRow inherits Rectangle {
    width: 100%;
    height: 56px;
    background: transparent;

    // -- Public API -----------------------------------------------------------

    in property <[LibraryTile]> libraries: [];
    in-out property <int> focused-index: 0;
    in-out property <bool> row-focused: false;

    callback library-selected(/* library_id */ string);

    // -- Internal state -------------------------------------------------------

    private property <length> tile-width: 120px;
    private property <length> tile-height: 40px;
    private property <length> tile-gap: 12px;
    private property <length> scroll-target: root.focused-index * (root.tile-width + root.tile-gap);

    // -- Layout ---------------------------------------------------------------

    Flickable {
        width: parent.width;
        height: parent.height;
        viewport-width: self.width;

        viewport-x: -root.scroll-target + Theme.overscan-h;

        animate viewport-x {
            duration: Theme.transition-duration;
            easing: ease-in-out;
        }

        HorizontalLayout {
            spacing: root.tile-gap;
            padding-left: Theme.overscan-h;
            padding-right: Theme.overscan-h;
            alignment: start;

            for lib[index] in root.libraries : Rectangle {
                width: root.tile-width;
                height: root.tile-height;
                border-radius: Theme.button-radius;
                background: root.row-focused && index == root.focused-index ? Theme.accent : Theme.surface;
                opacity: root.row-focused && index == root.focused-index ? 1.0 : 0.7;

                animate background { duration: Theme.focus-duration; easing: ease-out; }
                animate opacity { duration: Theme.focus-duration; easing: ease-out; }

                // Focus glow border
                Rectangle {
                    width: parent.width + 2px;
                    height: parent.height + 2px;
                    x: -1px;
                    y: -1px;
                    border-radius: Theme.button-radius + 1px;
                    border-width: 1px;
                    border-color: root.row-focused && index == root.focused-index ? Theme.accent : transparent;
                    background: transparent;

                    animate border-color { duration: Theme.focus-duration; easing: ease-out; }
                }

                Text {
                    text: lib.name;
                    font-size: Theme.font-body-medium;
                    color: root.row-focused && index == root.focused-index ? #ffffff : Theme.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;

                    animate color { duration: Theme.focus-duration; easing: ease-out; }
                }

                TouchArea {
                    clicked => {
                        root.focused-index = index;
                        root.library-selected(lib.id);
                    }
                }
            }
        }
    }

    // -- Focus scope for D-pad navigation -------------------------------------

    FocusScope {
        width: 0px;
        height: 0px;
        enabled: root.row-focused;

        key-pressed(event) => {
            if (event.text == Key.RightArrow) {
                if (root.focused-index < root.libraries.length - 1) {
                    root.focused-index += 1;
                }
                return accept;
            }
            if (event.text == Key.LeftArrow) {
                if (root.focused-index > 0) {
                    root.focused-index -= 1;
                }
                return accept;
            }
            if (event.text == Key.Return || event.text == " ") {
                if (root.focused-index >= 0 && root.focused-index < root.libraries.length) {
                    root.library-selected(root.libraries[root.focused-index].id);
                }
                return accept;
            }
            return reject;
        }
    }
}
