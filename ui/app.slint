import { Theme, MediaItem, ContentRowData, UserInfo, PlayerState, SearchResult, ChapterInfo, MediaSegmentInfo } from "theme.slint";
import { HomeScreen } from "home.slint";
import { DetailScreen } from "detail.slint";
import { PlayerOverlay } from "player.slint";
import { LoginScreen } from "login.slint";
import { SearchScreen } from "search.slint";
import { LibraryScreen } from "library.slint";
import { SettingsScreen } from "settings.slint";
import { Screensaver } from "screensaver.slint";
import { LoadingSpinner } from "loading.slint";
import { ConfirmPopup } from "popup.slint";
import { LibraryTile, LibraryTilesRow } from "library-tiles.slint";
import { NowPlayingBar } from "now-playing-bar.slint";
import { CastMember, CastCrewRow, GenreTag, GenreRow } from "cast-crew.slint";
import { ChapterListPopup } from "chapters.slint";
import { TrickplayPreview } from "trickplay.slint";
import { PlaylistItem, PlaylistSidebar } from "playlist.slint";
import { MusicTrack, MusicPlayer } from "music-player.slint";
import { JellyfinBranding } from "branding.slint";

export global AppBridge {
    // Navigation
    callback navigate(/* screen */ string, /* param */ string);
    callback go-back();

    // Auth
    callback login(/* user_id */ string, /* password */ string);
    callback logout();
    callback retry-connection();

    // Content loading
    callback request-home-data();
    callback request-library(/* library_id */ string, /* sort */ string, /* filter */ string);
    callback request-item-detail(/* item_id */ string);
    callback request-search(/* query */ string);
    callback request-seasons(/* series_id */ string);
    callback request-episodes(/* series_id */ string, /* season_id */ string);

    // Playback
    callback play-item(/* item_id */ string);
    callback play-pause();
    callback seek(/* position_ms */ int);
    callback stop-playback();
    callback next-track();
    callback prev-track();
    callback set-audio-track(/* index */ int);
    callback set-subtitle-track(/* index */ int);
    callback set-volume(/* level */ float);
    callback toggle-mute();

    // User actions
    callback toggle-favorite(/* item_id */ string);
    callback mark-played(/* item_id */ string);
    callback mark-unplayed(/* item_id */ string);

    // Library tiles
    callback library-selected(string);

    // Skip intro
    callback skip-segment();

    // Chapters
    callback show-chapters();
    callback seek-to-chapter(int);

    // Speed control
    callback speed-up();
    callback speed-down();

    // Subtitle delay
    callback subtitle-delay-adjust(/* delta_ms */ int);

    // Queue
    callback queue-play-item(/* index */ int);
    callback queue-remove-item(/* index */ int);
    callback toggle-shuffle();
    callback cycle-repeat();
    callback enqueue-next(/* item_id */ string);

    // Now playing bar
    callback now-playing-clicked();

    // Genre/cast
    callback genre-selected(string);
    callback person-selected(string);

    // State properties (set by Rust)
    in-out property <string> current-screen: "login";
    in-out property <bool> is-loading: false;
    in-out property <string> error-message: "";

    // Data properties (populated by Rust)
    in-out property <[UserInfo]> users: [];
    in-out property <[ContentRowData]> home-rows: [];
    in-out property <MediaItem> detail-item;
    in-out property <[MediaItem]> detail-related: [];
    in-out property <[MediaItem]> detail-seasons: [];
    in-out property <[MediaItem]> detail-episodes: [];
    in-out property <[MediaItem]> library-items: [];
    in-out property <string> library-title: "";
    in-out property <[SearchResult]> search-results: [];
    in-out property <PlayerState> player-state;
    in-out property <UserInfo> current-user;
    in-out property <bool> show-screensaver: false;
    in-out property <bool> show-popup: false;
    in-out property <string> popup-title: "";
    in-out property <string> popup-message: "";

    // Library tiles
    in property <[LibraryTile]> library-tiles;

    // Now playing bar
    in property <string> now-playing-title;
    in property <string> now-playing-subtitle;
    in property <image> now-playing-thumbnail;
    in property <float> now-playing-progress;
    in property <bool> now-playing-active;

    // Cast & crew
    in property <[CastMember]> cast-members;
    in property <[GenreTag]> genres;

    // Chapters
    in property <[ChapterInfo]> chapters;

    // Skip intro/credits
    in property <bool> show-skip-button;
    in property <string> skip-button-label;

    // Playback speed
    in property <string> speed-label: "1.0x";

    // Playlist/queue
    in property <[PlaylistItem]> queue-items;
    in property <int> queue-current-index;
    in property <bool> show-playlist;
    in property <bool> shuffle-active;
    in property <int> repeat-mode;

    // Media player preference
    in property <string> media-player: "vlc";
    callback toggle-media-player();

    // Trickplay
    in property <image> trickplay-thumbnail;
    in property <string> trickplay-timestamp;
    in property <bool> trickplay-scrubbing;
}

export component AppWindow inherits Window {
    title: "Pi-Media-Player";
    background: Theme.background;
    // Note: default-font-family and default-font-size set by system defaults
    width: 1920px;
    height: 1080px;

    // Global key handler
    FocusScope {
        width: 100%;
        height: 100%;
        init => { self.focus(); }

        key-pressed(event) => {
            if (event.text == Key.Escape) {
                if (AppBridge.error-message != "") {
                    AppBridge.error-message = "";
                    AppBridge.is-loading = false;
                    return accept;
                }
                if (AppBridge.is-loading) {
                    AppBridge.is-loading = false;
                }
                AppBridge.go-back();
                return accept;
            }
            // Home key navigates to home screen
            if (event.text == Key.F1) {
                AppBridge.navigate("home", "");
                return accept;
            }
            return reject;
        }

        // Screen layers - only one visible at a time based on current-screen

        if AppBridge.current-screen == "login" : LoginScreen {
            width: 100%;
            height: 100%;
            users: AppBridge.users;
            error: AppBridge.error-message;
            select-user(id) => {
                AppBridge.login(id, "");
            }
            submit-password(user-id, password) => {
                AppBridge.login(user-id, password);
            }
            request-quick-connect() => {
                AppBridge.retry-connection();
            }
        }

        if AppBridge.current-screen == "home" : HomeScreen {
            width: 100%;
            height: 100%;
            rows: AppBridge.home-rows;
            current-user: AppBridge.current-user;
            item-selected(id) => {
                AppBridge.navigate("detail", id);
            }
            item-play(id) => {
                AppBridge.play-item(id);
            }
            open-search() => {
                AppBridge.navigate("search", "");
            }
            open-settings() => {
                AppBridge.navigate("settings", "");
            }
            open-library(id) => {
                AppBridge.navigate("library", id);
            }
        }

        if AppBridge.current-screen == "detail" : DetailScreen {
            width: 100%;
            height: 100%;
            item: AppBridge.detail-item;
            related-items: AppBridge.detail-related;
            seasons: AppBridge.detail-seasons;
            episodes: AppBridge.detail-episodes;
            genres: AppBridge.genres;
            cast-members: AppBridge.cast-members;
            play-item(item-id) => {
                AppBridge.play-item(item-id);
            }
            navigate(screen, param) => {
                AppBridge.navigate(screen, param);
            }
            go-back() => {
                AppBridge.go-back();
            }
            toggle-favorite(item-id) => {
                AppBridge.toggle-favorite(item-id);
            }
            mark-played(item-id) => {
                AppBridge.mark-played(item-id);
            }
            mark-unplayed(item-id) => {
                AppBridge.mark-unplayed(item-id);
            }
            request-seasons(series-id) => {
                AppBridge.request-seasons(series-id);
            }
            request-episodes(series-id, season-id) => {
                AppBridge.request-episodes(series-id, season-id);
            }
            genre-selected(name) => {
                AppBridge.genre-selected(name);
            }
            person-selected(id) => {
                AppBridge.person-selected(id);
            }
        }

        if AppBridge.current-screen == "search" : SearchScreen {
            width: 100%;
            height: 100%;
            results: AppBridge.search-results;
            search(query) => {
                AppBridge.request-search(query);
            }
            select-result(id) => {
                AppBridge.navigate("detail", id);
            }
            go-back() => {
                AppBridge.go-back();
            }
        }

        if AppBridge.current-screen == "library" : LibraryScreen {
            width: 100%;
            height: 100%;
            items: AppBridge.library-items;
            title: AppBridge.library-title;
            item-selected(id) => {
                AppBridge.navigate("detail", id);
            }
            sort-changed(sort) => {
                AppBridge.request-library("", sort, "");
            }
            filter-changed(filter) => {
                AppBridge.request-library("", "", filter);
            }
            go-back() => {
                AppBridge.go-back();
            }
        }

        if AppBridge.current-screen == "settings" : SettingsScreen {
            width: 100%;
            height: 100%;
            username: AppBridge.current-user.name;
            media-player: AppBridge.media-player;
            logout() => {
                AppBridge.logout();
            }
            toggle-media-player() => {
                AppBridge.toggle-media-player();
            }
            go-back() => {
                AppBridge.go-back();
            }
        }

        // Player overlay - sits on top of content screens when playing
        if AppBridge.current-screen == "player" : PlayerOverlay {
            width: 100%;
            height: 100%;
            state: AppBridge.player-state;
            play-pause() => {
                AppBridge.play-pause();
            }
            seek(position-ms) => {
                AppBridge.seek(position-ms);
            }
            seek-relative(offset-ms) => {
                AppBridge.seek(AppBridge.player-state.position-ms + offset-ms);
            }
            next-track() => {
                AppBridge.next-track();
            }
            prev-track() => {
                AppBridge.prev-track();
            }
            set-audio(index) => {
                AppBridge.set-audio-track(index);
            }
            set-subtitle(index) => {
                AppBridge.set-subtitle-track(index);
            }
            set-volume(level) => {
                AppBridge.set-volume(level);
            }
            toggle-mute() => {
                AppBridge.toggle-mute();
            }
            dismiss() => {
                AppBridge.stop-playback();
            }
        }

        // Now playing bar - visible when media is playing and not on the player screen
        if AppBridge.now-playing-active && AppBridge.current-screen != "player" : NowPlayingBar {
            width: 100%;
            y: parent.height - self.height;
            title: AppBridge.now-playing-title;
            subtitle: AppBridge.now-playing-subtitle;
            thumbnail: AppBridge.now-playing-thumbnail;
            progress: AppBridge.now-playing-progress;
            bar-visible: true;
            bar-clicked() => {
                AppBridge.now-playing-clicked();
            }
        }

        // Loading overlay - visible on top of all screens when loading
        if AppBridge.is-loading : Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.background.with-alpha(0.7);

            LoadingSpinner {
                width: 80px;
                height: 80px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                active: true;
            }

            // Escape must ALWAYS work, even during loading
            FocusScope {
                width: 100%;
                height: 100%;
                init => { self.focus(); }
                key-pressed(event) => {
                    if (event.text == Key.Escape) {
                        if (AppBridge.error-message != "") {
                            AppBridge.error-message = "";
                            AppBridge.is-loading = false;
                            return accept;
                        }
                        AppBridge.is-loading = false;
                        AppBridge.go-back();
                        return accept;
                    }
                    return reject;
                }
            }
        }

        // Error message overlay
        if AppBridge.error-message != "" && AppBridge.current-screen != "login" : Rectangle {
            width: 100%;
            height: 100%;
            background: Theme.background.with-alpha(0.85);

            FocusScope {
                width: 100%;
                height: 100%;
                init => { self.focus(); }
                key-pressed(event) => {
                    if (event.text == Key.Escape) {
                        AppBridge.error-message = "";
                        AppBridge.is-loading = false;
                        return accept;
                    }
                    return reject;
                }
            }

            Rectangle {
                width: 600px;
                height: 200px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: Theme.surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.error;

                VerticalLayout {
                    alignment: center;
                    padding: 32px;
                    spacing: 16px;

                    Text {
                        text: "Error";
                        color: Theme.error;
                        font-size: 24px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: AppBridge.error-message;
                        color: Theme.on-surface;
                        font-size: 16px;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    Text {
                        text: "Press Escape to dismiss";
                        color: Theme.text-secondary;
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // Confirm popup overlay
        if AppBridge.show-popup : ConfirmPopup {
            width: 100%;
            height: 100%;
            visible-popup: true;
            title: AppBridge.popup-title;
            message: AppBridge.popup-message;
            confirm() => {
                AppBridge.show-popup = false;
            }
            cancel() => {
                AppBridge.show-popup = false;
            }
        }

        // Screensaver - topmost layer
        if AppBridge.show-screensaver : Screensaver {
            active: true;
            width: 100%;
            height: 100%;
            dismiss() => {
                AppBridge.show-screensaver = false;
            }
        }
    }
}
