// Jellyfin Pi TV App - Search Screen
// On-screen keyboard with live search results grid

import { Theme, SearchResult } from "theme.slint";

// ============================================================================
// SearchScreen
// ============================================================================

export component SearchScreen inherits Rectangle {
    background: Theme.background;

    // -- Public API ----------------------------------------------------------

    in property <[SearchResult]> results: [];
    in-out property <string> query: "";
    in-out property <int> focused-section: 0;      // 0 = keyboard, 1 = results
    in-out property <int> focused-key: 0;
    in-out property <int> focused-key-row: 0;
    in-out property <int> focused-result: 0;

    callback search(string);
    callback select-result(string);
    callback go-back();

    // -- Internal helpers ----------------------------------------------------

    // Row lengths for bounds checking
    pure function row-length(row: int) -> int {
        if row == 0 { return 10; }
        if row == 1 { return 9; }
        if row == 2 { return 7; }
        return 3;   // row 3: Space, Backspace, Clear
    }

    // Results grid: 3 columns
    property <int> result-cols: 3;
    property <int> result-rows: results.length > 0
        ? ((results.length + result-cols - 1) / result-cols)
        : 0;

    // Cursor blink
    property <bool> cursor-visible: true;
    cursor-timer := Timer {
        interval: 530ms;
        running: true;
        triggered => { cursor-visible = !cursor-visible; }
    }

    // ========================================================================
    // Main layout: left (keyboard) | right (results)
    // ========================================================================

    HorizontalLayout {
        padding-left: Theme.overscan-h;
        padding-right: Theme.overscan-h;
        padding-top: Theme.overscan-v;
        padding-bottom: Theme.overscan-v;
        spacing: Theme.spacing-lg;

        // ====================================================================
        // LEFT SIDE — Search input + virtual keyboard (~40%)
        // ====================================================================

        VerticalLayout {
            width: 40%;
            spacing: Theme.spacing-lg;

            // -- Search input field ------------------------------------------

            Rectangle {
                height: 56px;
                background: Theme.surface;
                border-radius: Theme.button-radius;
                border-width: focused-section == 0 ? 2px : 0px;
                border-color: Theme.accent;

                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    alignment: start;

                    // Search icon placeholder
                    Text {
                        text: "\u{1F50D}";
                        font-size: 18px;
                    }

                    Rectangle { width: Theme.spacing-sm; }

                    // Query text + cursor
                    HorizontalLayout {
                        alignment: start;

                        Text {
                            text: query == "" ? "Search..." : query;
                            font-size: Theme.font-title-medium;
                            color: query == "" ? Theme.text-tertiary : Theme.text-primary;
                            overflow: elide;
                        }

                        // Blinking cursor
                        Rectangle {
                            width: query != "" || cursor-visible ? 2px : 0px;
                            height: 28px;
                            background: cursor-visible && focused-section == 0
                                ? Theme.accent : transparent;
                        }
                    }
                }
            }

            // -- Virtual keyboard --------------------------------------------

            VerticalLayout {
                spacing: Theme.spacing-sm;

                // Row 0: Q W E R T Y U I O P
                HorizontalLayout {
                    spacing: 4px;
                    for letter[idx] in ["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P"] :
                    Rectangle {
                        width: 56px;
                        height: 48px;
                        border-radius: 6px;
                        background: focused-section == 0 && focused-key-row == 0 && focused-key == idx
                            ? Theme.accent : Theme.surface;
                        animate background { duration: Theme.focus-duration; }

                        Text {
                            text: letter;
                            font-size: Theme.font-body-large;
                            color: focused-section == 0 && focused-key-row == 0 && focused-key == idx
                                ? white : Theme.text-primary;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Row 1: A S D F G H J K L
                HorizontalLayout {
                    spacing: 4px;
                    // Offset for staggered look
                    Rectangle { width: 14px; }

                    for letter[idx] in ["A", "S", "D", "F", "G", "H", "J", "K", "L"] :
                    Rectangle {
                        width: 56px;
                        height: 48px;
                        border-radius: 6px;
                        background: focused-section == 0 && focused-key-row == 1 && focused-key == idx
                            ? Theme.accent : Theme.surface;
                        animate background { duration: Theme.focus-duration; }

                        Text {
                            text: letter;
                            font-size: Theme.font-body-large;
                            color: focused-section == 0 && focused-key-row == 1 && focused-key == idx
                                ? white : Theme.text-primary;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Row 2: Z X C V B N M
                HorizontalLayout {
                    spacing: 4px;
                    Rectangle { width: 28px; }

                    for letter[idx] in ["Z", "X", "C", "V", "B", "N", "M"] :
                    Rectangle {
                        width: 56px;
                        height: 48px;
                        border-radius: 6px;
                        background: focused-section == 0 && focused-key-row == 2 && focused-key == idx
                            ? Theme.accent : Theme.surface;
                        animate background { duration: Theme.focus-duration; }

                        Text {
                            text: letter;
                            font-size: Theme.font-body-large;
                            color: focused-section == 0 && focused-key-row == 2 && focused-key == idx
                                ? white : Theme.text-primary;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Row 3: Space | Backspace | Clear
                HorizontalLayout {
                    spacing: 4px;

                    // Space bar (wide)
                    Rectangle {
                        width: 200px;
                        height: 48px;
                        border-radius: 6px;
                        background: focused-section == 0 && focused-key-row == 3 && focused-key == 0
                            ? Theme.accent : Theme.surface;
                        animate background { duration: Theme.focus-duration; }

                        Text {
                            text: "SPACE";
                            font-size: Theme.font-body-medium;
                            color: focused-section == 0 && focused-key-row == 3 && focused-key == 0
                                ? white : Theme.text-secondary;
                            horizontal-alignment: center;
                        }
                    }

                    // Backspace
                    Rectangle {
                        width: 110px;
                        height: 48px;
                        border-radius: 6px;
                        background: focused-section == 0 && focused-key-row == 3 && focused-key == 1
                            ? Theme.accent : Theme.surface;
                        animate background { duration: Theme.focus-duration; }

                        Text {
                            text: "\u{232B} DEL";
                            font-size: Theme.font-body-medium;
                            color: focused-section == 0 && focused-key-row == 3 && focused-key == 1
                                ? white : Theme.text-secondary;
                            horizontal-alignment: center;
                        }
                    }

                    // Clear
                    Rectangle {
                        width: 90px;
                        height: 48px;
                        border-radius: 6px;
                        background: focused-section == 0 && focused-key-row == 3 && focused-key == 2
                            ? Theme.accent : Theme.surface-variant;
                        animate background { duration: Theme.focus-duration; }

                        Text {
                            text: "CLR";
                            font-size: Theme.font-body-medium;
                            color: focused-section == 0 && focused-key-row == 3 && focused-key == 2
                                ? white : Theme.text-secondary;
                            horizontal-alignment: center;
                        }
                    }
                }
            }

            // Spacer to push keyboard up
            Rectangle { vertical-stretch: 1; }
        }

        // ====================================================================
        // RIGHT SIDE — Results grid (~60%)
        // ====================================================================

        VerticalLayout {
            width: 60%;
            spacing: Theme.spacing-md;

            // Results header
            Text {
                text: results.length > 0
                    ? "Results (" + results.length + ")"
                    : (query != "" ? "No results" : "");
                font-size: Theme.font-title-small;
                color: Theme.text-secondary;
                height: 28px;
            }

            // Results grid (scrollable)
            Flickable {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: Theme.spacing-md;

                    for row-idx in result-rows :
                    HorizontalLayout {
                        spacing: Theme.spacing-md;

                        for col-idx in 3 :
                        Rectangle {
                            visible: row-idx * 3 + col-idx < results.length;
                            property <int> item-index: row-idx * 3 + col-idx;
                            property <bool> is-focused:
                                focused-section == 1 && focused-result == item-index;

                            width: 178px;
                            height: 220px;
                            border-radius: Theme.card-radius;
                            background: Theme.card-background;
                            border-width: is-focused ? 3px : 0px;
                            border-color: Theme.accent;

                            // Scale on focus
                            property <float> card-scale: is-focused ? 1.1 : 1.0;
                            animate card-scale { duration: Theme.focus-duration; }

                            VerticalLayout {
                                padding: 0px;

                                // Thumbnail
                                Rectangle {
                                    height: 150px;
                                    clip: true;
                                    border-radius: Theme.card-radius;

                                    Image {
                                        source: results[row-idx * 3 + col-idx].image-source;
                                        width: 100%;
                                        height: 100%;
                                        image-fit: cover;
                                    }

                                    // Gradient overlay at bottom
                                    Rectangle {
                                        y: parent.height - 40px;
                                        height: 40px;
                                        background: @linear-gradient(
                                            180deg, transparent 0%, #00000088 100%);
                                    }
                                }

                                // Title + subtitle
                                VerticalLayout {
                                    padding: Theme.spacing-sm;
                                    spacing: 2px;

                                    Text {
                                        text: results[row-idx * 3 + col-idx].title;
                                        font-size: Theme.font-body-medium;
                                        color: Theme.text-primary;
                                        overflow: elide;
                                        wrap: word-wrap;
                                    }

                                    Text {
                                        text: {
                                            results[row-idx * 3 + col-idx].year != ""
                                                ? results[row-idx * 3 + col-idx].year
                                                    + " \u{2022} "
                                                    + results[row-idx * 3 + col-idx].item-type
                                                : results[row-idx * 3 + col-idx].item-type;
                                        }
                                        font-size: Theme.font-body-small;
                                        color: Theme.text-secondary;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ========================================================================
    // Key handling
    // ========================================================================

    // Helper: resolve which character to type for given row/col
    pure function key-char(row: int, col: int) -> string {
        if row == 0 {
            if col == 0 { return "q"; }
            if col == 1 { return "w"; }
            if col == 2 { return "e"; }
            if col == 3 { return "r"; }
            if col == 4 { return "t"; }
            if col == 5 { return "y"; }
            if col == 6 { return "u"; }
            if col == 7 { return "i"; }
            if col == 8 { return "o"; }
            return "p";
        }
        if row == 1 {
            if col == 0 { return "a"; }
            if col == 1 { return "s"; }
            if col == 2 { return "d"; }
            if col == 3 { return "f"; }
            if col == 4 { return "g"; }
            if col == 5 { return "h"; }
            if col == 6 { return "j"; }
            if col == 7 { return "k"; }
            return "l";
        }
        if row == 2 {
            if col == 0 { return "z"; }
            if col == 1 { return "x"; }
            if col == 2 { return "c"; }
            if col == 3 { return "v"; }
            if col == 4 { return "b"; }
            if col == 5 { return "n"; }
            return "m";
        }
        return " "; // space for row 3
    }

    focus-scope := FocusScope {
        key-pressed(event) => {
            // B or Escape => go back
            if event.text == "\u{1b}" || event.text == "b" || event.text == "B" {
                go-back();
                return accept;
            }

            // --- Keyboard section ---
            if focused-section == 0 {
                // Navigate up
                if event.text == Key.UpArrow {
                    if focused-key-row > 0 {
                        focused-key-row -= 1;
                        if focused-key >= root.row-length(focused-key-row) {
                            focused-key = root.row-length(focused-key-row) - 1;
                        }
                    }
                    return accept;
                }

                // Navigate down
                if event.text == Key.DownArrow {
                    if focused-key-row < 3 {
                        focused-key-row += 1;
                        if focused-key >= root.row-length(focused-key-row) {
                            focused-key = root.row-length(focused-key-row) - 1;
                        }
                    }
                    return accept;
                }

                // Navigate left
                if event.text == Key.LeftArrow {
                    if focused-key > 0 {
                        focused-key -= 1;
                    }
                    return accept;
                }

                // Navigate right or jump to results
                if event.text == Key.RightArrow {
                    if focused-key < root.row-length(focused-key-row) - 1 {
                        focused-key += 1;
                    } else if results.length > 0 {
                        focused-section = 1;
                        focused-result = 0;
                    }
                    return accept;
                }

                // Tab => jump to results
                if event.text == Key.Tab {
                    if results.length > 0 {
                        focused-section = 1;
                        focused-result = 0;
                    }
                    return accept;
                }

                // Enter => type the focused key
                if event.text == Key.Return {
                    if focused-key-row <= 2 {
                        // Letter key
                        query = query + root.key-char(focused-key-row, focused-key);
                        search(query);
                    } else if focused-key-row == 3 {
                        if focused-key == 0 {
                            // Space
                            query = query + " ";
                            search(query);
                        } else if focused-key == 1 {
                            // Backspace — remove last character
                            if query.character-count > 0 {
                                // backspace handled by Rust via __BACKSPACE__ marker
                                // Slint doesn't have substring; handled in Rust
                                // Signal search with special marker
                                search("__BACKSPACE__");
                            }
                        } else if focused-key == 2 {
                            // Clear
                            query = "";
                            search("");
                        }
                    }
                    return accept;
                }
            }

            // --- Results section ---
            if focused-section == 1 {
                // Left => back to keyboard or move in grid
                if event.text == Key.LeftArrow {
                    if focused-result - (focused-result / result-cols) * result-cols == 0 {
                        focused-section = 0;
                    } else {
                        focused-result -= 1;
                    }
                    return accept;
                }

                // Right
                if event.text == Key.RightArrow {
                    if focused-result < results.length - 1
                        && focused-result - (focused-result / result-cols) * result-cols < result-cols - 1 {
                        focused-result += 1;
                    }
                    return accept;
                }

                // Up
                if event.text == Key.UpArrow {
                    if focused-result >= result-cols {
                        focused-result -= result-cols;
                    }
                    return accept;
                }

                // Down
                if event.text == Key.DownArrow {
                    if focused-result + result-cols < results.length {
                        focused-result += result-cols;
                    }
                    return accept;
                }

                // Tab => back to keyboard
                if event.text == Key.Tab {
                    focused-section = 0;
                    return accept;
                }

                // Enter => select result
                if event.text == Key.Return {
                    if focused-result < results.length {
                        select-result(results[focused-result].id);
                    }
                    return accept;
                }
            }

            return reject;
        }
    }
}
