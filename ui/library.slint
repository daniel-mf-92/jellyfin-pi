// Jellyfin Pi TV App - Library Browser / Grid Screen
// Displays a grid of items from a specific library (Movies, TV Shows, etc.)
// with sort/filter toolbar and keyboard-driven grid navigation.

import { Theme, MediaItem } from "theme.slint";
import { MediaCard } from "card.slint";

export component LibraryScreen inherits Rectangle {
    in property <string> title: "";
    in property <[MediaItem]> items: [];
    in property <[string]> sort-options: ["Name", "Date Added", "Rating", "Year", "Runtime"];
    in property <[string]> filter-options: ["All", "Unplayed", "Played", "Favorites", "Resumable"];
    in-out property <int> current-sort: 0;
    in-out property <int> current-filter: 0;
    in-out property <int> focused-section: 0;   // 0 = sort/filter bar, 1 = grid
    in-out property <int> focused-item: 0;
    in-out property <int> columns: 6;

    callback item-selected(string, string);
    callback library-query-changed(string, string);
    callback load-more();
    callback go-back();

    // -- Derived layout metrics -----------------------------------------------
    // Use the base poster footprint for grid layout math; focus scaling should
    // only affect the focused card visual, not every cell's spacing/position.
    private property <length> card-w: Theme.poster-width;
    private property <length> card-h: Theme.poster-height + 40px;
    private property <length> h-gap: Theme.card-gap;
    private property <length> v-gap: Theme.spacing-lg;
    private property <length> grid-padding: Theme.overscan-h;
    private property <length> header-height: 60px;
    private property <int> effective-columns: max(1, columns);
    private property <length> grid-content-width:
        (root.effective-columns * root.card-w)
        + ((root.effective-columns - 1) * root.h-gap)
        + (root.grid-padding * 2);
    private property <int> safe-focused-item:
        root.items.length > 0
            ? max(0, min(root.focused-item, root.items.length - 1))
            : 0;
    private property <int> total-rows: items.length > 0 ? ((items.length - 1) / root.effective-columns) + 1 : 0;
    private property <int> focused-row: root.safe-focused-item / root.effective-columns;
    private property <int> focused-col: root.safe-focused-item - (root.safe-focused-item / root.effective-columns) * root.effective-columns;
    // 0 = sort button focused in toolbar, 1 = filter button
    private property <int> toolbar-focus: 0;

    width: 100%;
    height: 100%;
    background: Theme.background;

    // =========================================================================
    // Header bar
    // =========================================================================
    header := Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: root.header-height;
        background: Theme.surface;

        // Library title
        Text {
            x: root.grid-padding;
            text: root.title;
            font-size: Theme.font-title-medium;
            color: Theme.text-primary;
            vertical-alignment: center;
            height: parent.height;
        }

        // Sort button
        sort-btn := Rectangle {
            x: parent.width - root.grid-padding - self.width - filter-btn.width - Theme.spacing-sm;
            y: (parent.height - self.height) / 2;
            width: sort-label.preferred-width + 24px;
            height: 36px;
            border-radius: Theme.button-radius;
            background: root.focused-section == 0 && root.toolbar-focus == 0
                ? Theme.accent : Theme.surface-variant;

            animate background { duration: Theme.focus-duration; easing: ease-out; }

            sort-label := Text {
                text: "Sort: " + (root.current-sort >= 0 && root.current-sort < root.sort-options.length
                    ? root.sort-options[root.current-sort] : "Name");
                font-size: Theme.font-body-medium;
                color: root.focused-section == 0 && root.toolbar-focus == 0
                    ? #ffffff : Theme.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;

                animate color { duration: Theme.focus-duration; easing: ease-out; }
            }

            TouchArea {
                clicked => {
                    root.current-sort = root.current-sort + 1 - ((root.current-sort + 1) / root.sort-options.length) * root.sort-options.length;
                    root.library-query-changed(
                        root.sort-options[root.current-sort],
                        root.filter-options[root.current-filter],
                    );
                }
            }
        }

        // Filter button
        filter-btn := Rectangle {
            x: parent.width - root.grid-padding - self.width;
            y: (parent.height - self.height) / 2;
            width: filter-label.preferred-width + 24px;
            height: 36px;
            border-radius: Theme.button-radius;
            background: root.focused-section == 0 && root.toolbar-focus == 1
                ? Theme.accent : Theme.surface-variant;

            animate background { duration: Theme.focus-duration; easing: ease-out; }

            filter-label := Text {
                text: "Filter: " + (root.current-filter >= 0 && root.current-filter < root.filter-options.length
                    ? root.filter-options[root.current-filter] : "All");
                font-size: Theme.font-body-medium;
                color: root.focused-section == 0 && root.toolbar-focus == 1
                    ? #ffffff : Theme.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;

                animate color { duration: Theme.focus-duration; easing: ease-out; }
            }

            TouchArea {
                clicked => {
                    root.current-filter = root.current-filter + 1 - ((root.current-filter + 1) / root.filter-options.length) * root.filter-options.length;
                    root.library-query-changed(
                        root.sort-options[root.current-sort],
                        root.filter-options[root.current-filter],
                    );
                }
            }
        }
    }

    // =========================================================================
    // Empty state
    // =========================================================================
    if items.length == 0 : Rectangle {
        x: 0;
        y: root.header-height;
        width: parent.width;
        height: parent.height - root.header-height;

        Text {
            text: "No items found";
            font-size: Theme.font-title-small;
            color: Theme.text-secondary;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // =========================================================================
    // Item grid (Flickable)
    // =========================================================================
    if items.length > 0 : Flickable {
        x: 0;
        y: root.header-height;
        width: parent.width;
        height: parent.height - root.header-height;
        viewport-width: max(self.width, root.grid-content-width);
        viewport-height: root.total-rows * (root.card-h + root.v-gap) + root.v-gap;
        interactive: false;   // scrolling driven by focus, not touch

        // Auto-scroll to keep focused item visible
        property <length> target-y: root.focused-row * (root.card-h + root.v-gap);
        property <length> view-h: self.height;

        // If focused card is below visible area, scroll down
        // If focused card is above visible area, scroll up
        viewport-y: min(0px,
            max(-(self.viewport-height - self.height),
                -max(0px, target-y - view-h / 2 + root.card-h / 2)));

        for item[index] in items : MediaCard {
            x: (index - (index / root.effective-columns) * root.effective-columns) * (root.card-w + root.h-gap) + root.grid-padding;
            y: (index / root.effective-columns) * (root.card-h + root.v-gap) + root.v-gap;
            item: item;
            is-landscape: false;
            show-title: true;
            focused: root.focused-section == 1 && root.focused-item == index;

            selected(id) => {
                root.item-selected(id, item.item-type);
            }

            play-requested(id) => {
                root.item-selected(id, item.item-type);
            }
        }

    }

    // =========================================================================
    // Keyboard / remote navigation
    // =========================================================================
    focus-scope := FocusScope {
        init => { self.focus(); }
        width: 0;
        height: 0;

        key-pressed(event) => {
            if (root.items.length > 0 && root.focused-item != root.safe-focused-item) {
                root.focused-item = root.safe-focused-item;
            }

            if (
                event.text == Key.Escape
                || event.text == "Escape"
                || event.text == "b"
                || event.text == "B"
            ) {
                root.go-back();
                return accept;
            }

            // -- Toolbar navigation (focused-section == 0) --------------------
            if (root.focused-section == 0) {
                if (
                    event.text == Key.LeftArrow
                    || event.text == "Left"
                    || event.text == "left"
                    || event.text == "ArrowLeft"
                ) {
                    if (root.toolbar-focus > 0) {
                        root.toolbar-focus -= 1;
                    }
                    return accept;
                }
                if (
                    event.text == Key.RightArrow
                    || event.text == "Right"
                    || event.text == "right"
                    || event.text == "ArrowRight"
                ) {
                    if (root.toolbar-focus < 1) {
                        root.toolbar-focus += 1;
                    }
                    return accept;
                }
                if (
                    event.text == Key.DownArrow
                    || event.text == "Down"
                    || event.text == "down"
                    || event.text == "ArrowDown"
                ) {
                    if (root.items.length > 0) {
                        root.focused-section = 1;
                        root.focused-item = 0;
                    }
                    return accept;
                }
                if (
                    event.text == Key.Return
                    || event.text == "Enter"
                    || event.text == " "
                    || event.text == "a"
                    || event.text == "A"
                ) {
                    if (root.toolbar-focus == 0) {
                        root.current-sort = root.current-sort + 1 - ((root.current-sort + 1) / root.sort-options.length) * root.sort-options.length;
                        root.library-query-changed(
                            root.sort-options[root.current-sort],
                            root.filter-options[root.current-filter],
                        );
                    } else {
                        root.current-filter = root.current-filter + 1 - ((root.current-filter + 1) / root.filter-options.length) * root.filter-options.length;
                        root.library-query-changed(
                            root.sort-options[root.current-sort],
                            root.filter-options[root.current-filter],
                        );
                    }
                    return accept;
                }
                return reject;
            }

            // -- Grid navigation (focused-section == 1) -----------------------
            if (root.focused-section == 1) {
                if (
                    event.text == Key.LeftArrow
                    || event.text == "Left"
                    || event.text == "left"
                    || event.text == "ArrowLeft"
                ) {
                    if (root.focused-col > 0) {
                        root.focused-item -= 1;
                    }
                    return accept;
                }
                if (
                    event.text == Key.RightArrow
                    || event.text == "Right"
                    || event.text == "right"
                    || event.text == "ArrowRight"
                ) {
                    if (root.focused-col < root.effective-columns - 1
                        && root.focused-item + 1 < root.items.length) {
                        root.focused-item += 1;
                    }
                    return accept;
                }
                if (
                    event.text == Key.UpArrow
                    || event.text == "Up"
                    || event.text == "up"
                    || event.text == "ArrowUp"
                ) {
                    if (root.focused-row == 0) {
                        // Move back to toolbar
                        root.focused-section = 0;
                    } else {
                        root.focused-item = max(0, root.focused-item - root.effective-columns);
                    }
                    return accept;
                }
                if (
                    event.text == Key.DownArrow
                    || event.text == "Down"
                    || event.text == "down"
                    || event.text == "ArrowDown"
                ) {
                    if (root.focused-item + root.effective-columns < root.items.length) {
                        root.focused-item += root.effective-columns;
                    } else if (root.focused-row < root.total-rows - 1) {
                        // Last partial row: clamp to last item
                        root.focused-item = root.items.length - 1;
                    }
                    return accept;
                }
                if (
                    event.text == Key.Return
                    || event.text == "Enter"
                    || event.text == " "
                    || event.text == "a"
                    || event.text == "A"
                ) {
                    if (root.focused-item >= 0 && root.focused-item < root.items.length) {
                        let selected-item = root.items[root.focused-item];
                        root.item-selected(selected-item.id, selected-item.item-type);
                    }
                    return accept;
                }
                return reject;
            }

            return reject;
        }
    }
}
