// Jellyfin Pi TV App - Home Screen Component
// Main browse screen with horizontal content rows (Jellyfin Android TV layout)

import { Theme, MediaItem, ContentRowData, UserInfo } from "theme.slint";
import { MediaCard } from "card.slint";
import { ContentRow } from "content-row.slint";

export component HomeScreen inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    // -- Public API -----------------------------------------------------------

    in property <[ContentRowData]> rows: [];
    in property <UserInfo> current-user;
    in property <string> current-time: "00:00";

    in-out property <int> focused-row: 0;
    in-out property <int> focused-col: 0;

    private property <int> safe-focused-row:
        root.rows.length > 0
            ? max(0, min(root.focused-row, root.rows.length - 1))
            : 0;
    private property <int> safe-focused-col:
        root.rows.length > 0 && root.rows[root.safe-focused-row].items.length > 0
            ? max(0, min(root.focused-col, root.rows[root.safe-focused-row].items.length - 1))
            : 0;

    callback item-selected(/* item_id */ string, /* item_type */ string);
    callback item-play(/* item_id */ string);
    callback open-search();
    callback open-settings();
    callback open-library(/* library_id */ string);
    callback retry-connection();

    pure function row-is-library-row(index: int) -> bool {
        if (index < 0 || index >= root.rows.length) {
            return false;
        }
        let title = root.rows[index].title;
        return title == "My Media" || title == "My Libraries" || title == "Libraries";
    }

    pure function item-type-is-library(item-type: string) -> bool {
        return item-type == "CollectionFolder"
            || item-type == "Folder"
            || item-type == "collectionfolder"
            || item-type == "folder";
    }


    // -- Internal state -------------------------------------------------------

    // Height of each content row (title + cards), excluding inter-row spacing.
    pure function row-block-height-for-index(index: int) -> length {
        let row-type = index >= 0 && index < root.rows.length
            ? root.rows[index].row-type
            : "poster";
        let cards-height = row-type == "landscape"
            ? (Theme.landscape-height + 120px)
            : (row-type == "square"
                ? (Theme.square-height + 120px)
                : (Theme.poster-height + 120px));
        return Theme.font-title-medium + 8px + cards-height;
    }

    pure function rows-height-through(index: int) -> length {
        let i = max(0, min(index, root.rows.length));
        return (i > 0 ? root.row-block-height-for-index(0) + Theme.spacing-lg : 0px)
            + (i > 1 ? root.row-block-height-for-index(1) + Theme.spacing-lg : 0px)
            + (i > 2 ? root.row-block-height-for-index(2) + Theme.spacing-lg : 0px)
            + (i > 3 ? root.row-block-height-for-index(3) + Theme.spacing-lg : 0px)
            + (i > 4 ? root.row-block-height-for-index(4) + Theme.spacing-lg : 0px)
            + (i > 5 ? root.row-block-height-for-index(5) + Theme.spacing-lg : 0px)
            + (i > 6 ? root.row-block-height-for-index(6) + Theme.spacing-lg : 0px)
            + (i > 7 ? root.row-block-height-for-index(7) + Theme.spacing-lg : 0px)
            + (i > 8 ? root.row-block-height-for-index(8) + Theme.spacing-lg : 0px)
            + (i > 9 ? root.row-block-height-for-index(9) + Theme.spacing-lg : 0px)
            + (i > 10 ? root.row-block-height-for-index(10) + Theme.spacing-lg : 0px)
            + (i > 11 ? root.row-block-height-for-index(11) + Theme.spacing-lg : 0px)
            + (i > 12 ? root.row-block-height-for-index(12) + Theme.spacing-lg : 0px)
            + (i > 13 ? root.row-block-height-for-index(13) + Theme.spacing-lg : 0px)
            + (i > 14 ? root.row-block-height-for-index(14) + Theme.spacing-lg : 0px)
            + (i > 15 ? root.row-block-height-for-index(15) + Theme.spacing-lg : 0px)
            + (i > 16 ? root.row-block-height-for-index(16) + Theme.spacing-lg : 0px)
            + (i > 17 ? root.row-block-height-for-index(17) + Theme.spacing-lg : 0px)
            + (i > 18 ? root.row-block-height-for-index(18) + Theme.spacing-lg : 0px)
            + (i > 19 ? root.row-block-height-for-index(19) + Theme.spacing-lg : 0px)
            + (i > 20 ? root.row-block-height-for-index(20) + Theme.spacing-lg : 0px)
            + (i > 21 ? root.row-block-height-for-index(21) + Theme.spacing-lg : 0px)
            + (i > 22 ? root.row-block-height-for-index(22) + Theme.spacing-lg : 0px)
            + (i > 23 ? root.row-block-height-for-index(23) + Theme.spacing-lg : 0px)
            + (i > 24 ? root.row-block-height-for-index(24) + Theme.spacing-lg : 0px)
            + (i > 25 ? root.row-block-height-for-index(25) + Theme.spacing-lg : 0px)
            + (i > 26 ? root.row-block-height-for-index(26) + Theme.spacing-lg : 0px)
            + (i > 27 ? root.row-block-height-for-index(27) + Theme.spacing-lg : 0px)
            + (i > 28 ? root.row-block-height-for-index(28) + Theme.spacing-lg : 0px)
            + (i > 29 ? root.row-block-height-for-index(29) + Theme.spacing-lg : 0px)
            + (i > 30 ? root.row-block-height-for-index(30) + Theme.spacing-lg : 0px)
            + (i > 31 ? root.row-block-height-for-index(31) + Theme.spacing-lg : 0px)
            + (i > 32 ? root.row-block-height-for-index(32) + Theme.spacing-lg : 0px)
            + (i > 33 ? root.row-block-height-for-index(33) + Theme.spacing-lg : 0px)
            + (i > 34 ? root.row-block-height-for-index(34) + Theme.spacing-lg : 0px)
            + (i > 35 ? root.row-block-height-for-index(35) + Theme.spacing-lg : 0px)
            + (i > 36 ? root.row-block-height-for-index(36) + Theme.spacing-lg : 0px)
            + (i > 37 ? root.row-block-height-for-index(37) + Theme.spacing-lg : 0px)
            + (i > 38 ? root.row-block-height-for-index(38) + Theme.spacing-lg : 0px)
            + (i > 39 ? root.row-block-height-for-index(39) + Theme.spacing-lg : 0px)
            + (i > 40 ? root.row-block-height-for-index(40) + Theme.spacing-lg : 0px)
            + (i > 41 ? root.row-block-height-for-index(41) + Theme.spacing-lg : 0px)
            + (i > 42 ? root.row-block-height-for-index(42) + Theme.spacing-lg : 0px)
            + (i > 43 ? root.row-block-height-for-index(43) + Theme.spacing-lg : 0px)
            + (i > 44 ? root.row-block-height-for-index(44) + Theme.spacing-lg : 0px)
            + (i > 45 ? root.row-block-height-for-index(45) + Theme.spacing-lg : 0px)
            + (i > 46 ? root.row-block-height-for-index(46) + Theme.spacing-lg : 0px)
            + (i > 47 ? root.row-block-height-for-index(47) + Theme.spacing-lg : 0px)
            + (i > 48 ? root.row-block-height-for-index(48) + Theme.spacing-lg : 0px)
            + (i > 49 ? root.row-block-height-for-index(49) + Theme.spacing-lg : 0px)
            + (i > 50 ? root.row-block-height-for-index(50) + Theme.spacing-lg : 0px)
            + (i > 51 ? root.row-block-height-for-index(51) + Theme.spacing-lg : 0px)
            + (i > 52 ? root.row-block-height-for-index(52) + Theme.spacing-lg : 0px)
            + (i > 53 ? root.row-block-height-for-index(53) + Theme.spacing-lg : 0px)
            + (i > 54 ? root.row-block-height-for-index(54) + Theme.spacing-lg : 0px)
            + (i > 55 ? root.row-block-height-for-index(55) + Theme.spacing-lg : 0px)
            + (i > 56 ? root.row-block-height-for-index(56) + Theme.spacing-lg : 0px)
            + (i > 57 ? root.row-block-height-for-index(57) + Theme.spacing-lg : 0px)
            + (i > 58 ? root.row-block-height-for-index(58) + Theme.spacing-lg : 0px)
            + (i > 59 ? root.row-block-height-for-index(59) + Theme.spacing-lg : 0px)
            + (i > 60 ? root.row-block-height-for-index(60) + Theme.spacing-lg : 0px)
            + (i > 61 ? root.row-block-height-for-index(61) + Theme.spacing-lg : 0px)
            + (i > 62 ? root.row-block-height-for-index(62) + Theme.spacing-lg : 0px)
            + (i > 63 ? root.row-block-height-for-index(63) + Theme.spacing-lg : 0px)
            + (i > 64 ? root.row-block-height-for-index(64) + Theme.spacing-lg : 0px)
            + (i > 65 ? root.row-block-height-for-index(65) + Theme.spacing-lg : 0px)
            + (i > 66 ? root.row-block-height-for-index(66) + Theme.spacing-lg : 0px)
            + (i > 67 ? root.row-block-height-for-index(67) + Theme.spacing-lg : 0px)
            + (i > 68 ? root.row-block-height-for-index(68) + Theme.spacing-lg : 0px)
            + (i > 69 ? root.row-block-height-for-index(69) + Theme.spacing-lg : 0px)
            + (i > 70 ? root.row-block-height-for-index(70) + Theme.spacing-lg : 0px)
            + (i > 71 ? root.row-block-height-for-index(71) + Theme.spacing-lg : 0px)
            + (i > 72 ? root.row-block-height-for-index(72) + Theme.spacing-lg : 0px)
            + (i > 73 ? root.row-block-height-for-index(73) + Theme.spacing-lg : 0px)
            + (i > 74 ? root.row-block-height-for-index(74) + Theme.spacing-lg : 0px)
            + (i > 75 ? root.row-block-height-for-index(75) + Theme.spacing-lg : 0px)
            + (i > 76 ? root.row-block-height-for-index(76) + Theme.spacing-lg : 0px)
            + (i > 77 ? root.row-block-height-for-index(77) + Theme.spacing-lg : 0px)
            + (i > 78 ? root.row-block-height-for-index(78) + Theme.spacing-lg : 0px)
            + (i > 79 ? root.row-block-height-for-index(79) + Theme.spacing-lg : 0px)
            + (i > 80 ? root.row-block-height-for-index(80) + Theme.spacing-lg : 0px)
            + (i > 81 ? root.row-block-height-for-index(81) + Theme.spacing-lg : 0px)
            + (i > 82 ? root.row-block-height-for-index(82) + Theme.spacing-lg : 0px)
            + (i > 83 ? root.row-block-height-for-index(83) + Theme.spacing-lg : 0px)
            + (i > 84 ? root.row-block-height-for-index(84) + Theme.spacing-lg : 0px)
            + (i > 85 ? root.row-block-height-for-index(85) + Theme.spacing-lg : 0px)
            + (i > 86 ? root.row-block-height-for-index(86) + Theme.spacing-lg : 0px)
            + (i > 87 ? root.row-block-height-for-index(87) + Theme.spacing-lg : 0px)
            + (i > 88 ? root.row-block-height-for-index(88) + Theme.spacing-lg : 0px)
            + (i > 89 ? root.row-block-height-for-index(89) + Theme.spacing-lg : 0px)
            + (i > 90 ? root.row-block-height-for-index(90) + Theme.spacing-lg : 0px)
            + (i > 91 ? root.row-block-height-for-index(91) + Theme.spacing-lg : 0px)
            + (i > 92 ? root.row-block-height-for-index(92) + Theme.spacing-lg : 0px)
            + (i > 93 ? root.row-block-height-for-index(93) + Theme.spacing-lg : 0px)
            + (i > 94 ? root.row-block-height-for-index(94) + Theme.spacing-lg : 0px)
            + (i > 95 ? root.row-block-height-for-index(95) + Theme.spacing-lg : 0px)
            + (i > 96 ? root.row-block-height-for-index(96) + Theme.spacing-lg : 0px)
            + (i > 97 ? root.row-block-height-for-index(97) + Theme.spacing-lg : 0px)
            + (i > 98 ? root.row-block-height-for-index(98) + Theme.spacing-lg : 0px)
            + (i > 99 ? root.row-block-height-for-index(99) + Theme.spacing-lg : 0px)
            + (i > 100 ? root.row-block-height-for-index(100) + Theme.spacing-lg : 0px)
            + (i > 101 ? root.row-block-height-for-index(101) + Theme.spacing-lg : 0px)
            + (i > 102 ? root.row-block-height-for-index(102) + Theme.spacing-lg : 0px)
            + (i > 103 ? root.row-block-height-for-index(103) + Theme.spacing-lg : 0px)
            + (i > 104 ? root.row-block-height-for-index(104) + Theme.spacing-lg : 0px)
            + (i > 105 ? root.row-block-height-for-index(105) + Theme.spacing-lg : 0px)
            + (i > 106 ? root.row-block-height-for-index(106) + Theme.spacing-lg : 0px)
            + (i > 107 ? root.row-block-height-for-index(107) + Theme.spacing-lg : 0px)
            + (i > 108 ? root.row-block-height-for-index(108) + Theme.spacing-lg : 0px)
            + (i > 109 ? root.row-block-height-for-index(109) + Theme.spacing-lg : 0px)
            + (i > 110 ? root.row-block-height-for-index(110) + Theme.spacing-lg : 0px)
            + (i > 111 ? root.row-block-height-for-index(111) + Theme.spacing-lg : 0px)
            + (i > 112 ? root.row-block-height-for-index(112) + Theme.spacing-lg : 0px)
            + (i > 113 ? root.row-block-height-for-index(113) + Theme.spacing-lg : 0px)
            + (i > 114 ? root.row-block-height-for-index(114) + Theme.spacing-lg : 0px)
            + (i > 115 ? root.row-block-height-for-index(115) + Theme.spacing-lg : 0px)
            + (i > 116 ? root.row-block-height-for-index(116) + Theme.spacing-lg : 0px)
            + (i > 117 ? root.row-block-height-for-index(117) + Theme.spacing-lg : 0px)
            + (i > 118 ? root.row-block-height-for-index(118) + Theme.spacing-lg : 0px)
            + (i > 119 ? root.row-block-height-for-index(119) + Theme.spacing-lg : 0px);
    }

    // Estimated viewport height for the rows region below the top bar.
    pure function rows-viewport-height() -> length {
        return max(0px, root.height - (Theme.overscan-v * 2) - 48px - Theme.spacing-sm);
    }

    // Total vertical extent of all rows including inter-row spacing.
    pure function rows-content-height() -> length {
        return root.rows.length > 0
            ? (root.rows-height-through(root.rows.length) - Theme.spacing-lg)
            : 0px;
    }

    // Target scroll offset to keep focused row visible
    pure function target-scroll-y() -> length {
        let max-scroll = max(0px, root.rows-content-height() - root.rows-viewport-height());
        let focused-row-index = root.safe-focused-row;
        let focused-row-height = root.row-block-height-for-index(focused-row-index);
        let focused-row-top = root.rows-height-through(focused-row-index);
        let focused-row-center = focused-row-top + (focused-row-height / 2);
        let raw-target = max(0px, focused-row-center - (root.rows-viewport-height() / 2));
        return -min(raw-target, max-scroll);
    }

    // -- Focus handling -------------------------------------------------------

    focus-scope := FocusScope {
        init => { self.focus(); }
        width: 100%;
        height: 100%;

        key-pressed(event) => {
            if (root.rows.length > 0) {
                if (root.focused-row != root.safe-focused-row) {
                    root.focused-row = root.safe-focused-row;
                }
                if (root.focused-col != root.safe-focused-col) {
                    root.focused-col = root.safe-focused-col;
                }
            }

            if (
                event.text == Key.UpArrow
                || event.text == "Up"
                || event.text == "up"
                || event.text == "ArrowUp"
            ) {
                if (root.focused-row > 0) {
                    root.focused-row -= 1;
                }
                return accept;
            }
            if (
                event.text == Key.DownArrow
                || event.text == "Down"
                || event.text == "down"
                || event.text == "ArrowDown"
            ) {
                if (root.focused-row < root.rows.length - 1) {
                    root.focused-row += 1;
                }
                return accept;
            }
            // Left/Right arrows navigate within the focused row
            if (
                event.text == Key.RightArrow
                || event.text == "Right"
                || event.text == "right"
                || event.text == "ArrowRight"
            ) {
                if (root.focused-row >= 0 && root.focused-row < root.rows.length) {
                    if (root.safe-focused-col < root.rows[root.focused-row].items.length - 1) {
                        root.focused-col = root.safe-focused-col + 1;
                    }
                }
                return accept;
            }
            if (
                event.text == Key.LeftArrow
                || event.text == "Left"
                || event.text == "left"
                || event.text == "ArrowLeft"
            ) {
                if (root.safe-focused-col > 0) {
                    root.focused-col = root.safe-focused-col - 1;
                }
                return accept;
            }
            if (
                event.text == Key.Home
                || event.text == "Home"
                || event.text == "home"
            ) {
                if (root.rows.length > 0) {
                    root.focused-row = 0;
                    root.focused-col = 0;
                }
                return accept;
            }
            // Enter/Space/A-button aliases → select item
            if (
                event.text == Key.Return ||
                event.text == "Enter" ||
                event.text == "Return" ||
                event.text == " " ||
                event.text == "a" ||
                event.text == "A"
            ) {
                if (root.rows.length == 0) {
                    root.retry-connection();
                    return accept;
                }
                if (root.focused-row >= 0 && root.focused-row < root.rows.length) {
                    if (root.focused-col >= 0 && root.focused-col < root.rows[root.focused-row].items.length) {
                        let focused-row-is-library = root.row-is-library-row(root.focused-row);
                        let selected-item = root.rows[root.focused-row].items[root.focused-col];
                        if (
                            focused-row-is-library
                            || root.item-type-is-library(
                                root.rows[root.focused-row].items[root.focused-col].item-type,
                            )
                        ) {
                            root.open-library(selected-item.id);
                        } else {
                            root.item-selected(selected-item.id, selected-item.item-type);
                        }
                    }
                }
                return accept;
            }
            // Y button / F2 → settings
            if (event.text == "y" || event.text == "Y" || event.text == Key.F2) {
                root.open-settings();
                return accept;
            }
            // X button / F3 → search
            if (event.text == "x" || event.text == "X" || event.text == Key.F3) {
                root.open-search();
                return accept;
            }
            return reject;
        }
    }

    // -- Layout ---------------------------------------------------------------

    VerticalLayout {
        padding-left: Theme.overscan-h;
        padding-right: Theme.overscan-h;
        padding-top: Theme.overscan-v;
        padding-bottom: Theme.overscan-v;

        // == Top bar ==========================================================
        top-bar := HorizontalLayout {
            height: 48px;
            alignment: end;
            spacing: Theme.spacing-md;
            padding-bottom: Theme.spacing-sm;

            // Spacer to push items right
            Rectangle { horizontal-stretch: 1; }

            // Clock
            Text {
                text: root.current-time;
                font-size: Theme.font-body-medium;
                color: Theme.text-secondary;
                vertical-alignment: center;
            }

            // Separator dot
            Text {
                text: "\u{2022}";
                font-size: Theme.font-body-medium;
                color: Theme.text-tertiary;
                vertical-alignment: center;
            }

            // User name
            Text {
                text: root.current-user.name;
                font-size: Theme.font-body-medium;
                color: Theme.text-secondary;
                vertical-alignment: center;
                font-weight: 600;
            }

            // User avatar
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: 16px;
                background: Theme.surface-variant;
                clip: true;

                Image {
                    width: 100%;
                    height: 100%;
                    source: root.current-user.avatar;
                    image-fit: cover;
                }

                // Fallback initial when no avatar
                Text {
                    visible: root.current-user.name != "";
                    text: root.current-user.name;
                    font-size: Theme.font-body-small;
                    color: Theme.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // == Scrollable content rows ==========================================
        Rectangle {
            vertical-stretch: 1;
            clip: true;

            if root.rows.length == 0 : Rectangle {
                width: 100%;
                height: 100%;

                VerticalLayout {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    alignment: center;
                    spacing: Theme.spacing-md;

                    Rectangle {
                        width: min(root.width - (Theme.overscan-h * 2), 1560px);
                        height: 300px;
                        border-radius: Theme.card-radius;
                        background: Theme.surface.with-alpha(0.9);

                        VerticalLayout {
                            width: 100%;
                            height: 100%;
                            padding-left: Theme.spacing-lg;
                            padding-right: Theme.spacing-lg;
                            padding-top: Theme.spacing-lg;
                            padding-bottom: Theme.spacing-lg;
                            spacing: Theme.spacing-md;

                            Text {
                                text: "My Media";
                                color: Theme.on-background;
                                font-size: Theme.font-title-large;
                                font-weight: 700;
                            }

                            HorizontalLayout {
                                spacing: Theme.spacing-md;

                                Rectangle {
                                    width: 460px;
                                    height: 170px;
                                    border-radius: Theme.card-radius;
                                    background: Theme.surface-variant.with-alpha(0.95);

                                    Text {
                                        text: "Movies";
                                        color: Theme.on-background;
                                        font-size: Theme.font-title-medium;
                                        font-weight: 700;
                                        x: 20px;
                                        y: parent.height - self.height - 18px;
                                    }
                                }

                                Rectangle {
                                    width: 460px;
                                    height: 170px;
                                    border-radius: Theme.card-radius;
                                    background: Theme.surface-variant.with-alpha(0.95);

                                    Text {
                                        text: "TV Shows";
                                        color: Theme.on-background;
                                        font-size: Theme.font-title-medium;
                                        font-weight: 700;
                                        x: 20px;
                                        y: parent.height - self.height - 18px;
                                    }
                                }

                                Rectangle {
                                    width: 460px;
                                    height: 170px;
                                    border-radius: Theme.card-radius;
                                    background: Theme.surface-variant.with-alpha(0.95);

                                    Text {
                                        text: "Collections";
                                        color: Theme.on-background;
                                        font-size: Theme.font-title-medium;
                                        font-weight: 700;
                                        x: 20px;
                                        y: parent.height - self.height - 18px;
                                    }
                                }
                            }
                        }
                    }

                    Text {
                        text: "Waiting for Jellyfin";
                        color: Theme.on-background;
                        font-size: Theme.font-title-large;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Press A / Enter to retry connection.";
                        color: Theme.text-secondary;
                        font-size: Theme.font-body-large;
                        horizontal-alignment: center;
                    }
                }
            }

            if root.rows.length > 0 : VerticalLayout {
                y: root.target-scroll-y();
                animate y {
                    duration: Theme.transition-duration;
                    easing: ease-in-out;
                }
                spacing: Theme.spacing-lg;

                for row[index] in root.rows : ContentRow {
                    title: row.title;
                    items: row.items;
                    is-landscape: row.row-type == "landscape";
                    is-square: row.row-type == "square";
                    include-horizontal-overscan: false;
                    row-focused: index == root.safe-focused-row;
                    // Keep rows from snapping back to column 0 when moving
                    // vertically, so horizontal position follows Jellyfin TV
                    // behavior across row transitions.
                    focused-index: root.safe-focused-col;

                    item-selected(id, item-type) => {
                        if (
                            root.row-is-library-row(index)
                            || item-type == "CollectionFolder"
                            || item-type == "Folder"
                            || item-type == "collectionfolder"
                            || item-type == "folder"
                        ) {
                            root.open-library(id);
                        } else {
                            root.item-selected(id, item-type);
                        }
                    }
                    item-play-requested(id) => {
                        root.item-play(id);
                    }
                }
            }
        }
    }
}
