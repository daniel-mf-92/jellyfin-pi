// Jellyfin Pi TV App - Loading Spinner Component

import { Theme } from "theme.slint";

export component LoadingSpinner inherits Rectangle {
    in property <bool> active: false;
    in property <string> message: "Loading...";

    // Driven by a Timer at 200ms instead of an iteration-count:-1 animation,
    // so the Slint render loop is not pinned at full-frame redraw while the
    // spinner is on screen. Previously this cost ~100% of one CPU core, which
    // also tripped the master-script CPU watchdog.
    property <int> tick: 0;

    visible: active;
    width: 100%;
    height: 100%;
    background: Theme.scrim;

    pulse-timer := Timer {
        interval: 200ms;
        running: active;
        triggered => {
            tick = mod(tick + 1, 6);
        }
    }

    VerticalLayout {
        alignment: center;

        HorizontalLayout {
            alignment: center;

            // Three dots; the active pair lights up on its tick. No interpolated
            // animations — state changes are direct so the renderer settles.
            HorizontalLayout {
                spacing: 12px;
                alignment: center;
                height: 56px;

                Rectangle {
                    property <bool> on: root.tick == 0 || root.tick == 1;
                    width: on ? 18px : 12px;
                    height: self.width;
                    border-radius: self.width / 2;
                    background: Theme.accent;
                    opacity: on ? 1.0 : 0.4;
                }

                Rectangle {
                    property <bool> on: root.tick == 2 || root.tick == 3;
                    width: on ? 18px : 12px;
                    height: self.width;
                    border-radius: self.width / 2;
                    background: Theme.accent;
                    opacity: on ? 1.0 : 0.4;
                }

                Rectangle {
                    property <bool> on: root.tick == 4 || root.tick == 5;
                    width: on ? 18px : 12px;
                    height: self.width;
                    border-radius: self.width / 2;
                    background: Theme.accent;
                    opacity: on ? 1.0 : 0.4;
                }
            }
        }

        // Message text
        HorizontalLayout {
            alignment: center;
            padding-top: Theme.spacing-md;

            Text {
                text: root.message;
                font-size: Theme.font-body-large;
                color: Theme.text-secondary;
                horizontal-alignment: center;
            }
        }
    }
}
