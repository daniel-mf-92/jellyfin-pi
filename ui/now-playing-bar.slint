// Jellyfin Pi TV App - Now Playing Bar Component
// Persistent bottom strip showing current playback status.
// Matches Jellyfin web client mini-player bar.

import { Theme } from "theme.slint";

export component NowPlayingBar inherits Rectangle {
    width: 100%;
    height: 60px;
    background: Theme.surface;
    visible: root.bar-visible;

    // -- Public API -----------------------------------------------------------

    in property <string> title: "";
    in property <string> subtitle: "";
    in property <image> thumbnail;
    in property <float> progress: 0.0;
    in property <bool> is-playing: false;
    in-out property <bool> bar-visible: false;

    callback bar-clicked();

    // -- Top border line ------------------------------------------------------

    Rectangle {
        width: parent.width;
        height: 1px;
        y: 0px;
        background: Theme.surface-variant;
    }

    // -- Main content layout --------------------------------------------------

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        padding-top: Theme.spacing-sm;
        padding-bottom: Theme.spacing-sm;
        spacing: Theme.spacing-md;
        alignment: stretch;

        // == Left: Thumbnail + text ===========================================
        HorizontalLayout {
            spacing: Theme.spacing-sm;
            horizontal-stretch: 1;

            // Thumbnail
            Rectangle {
                width: 50px;
                height: 50px;
                border-radius: 4px;
                background: Theme.surface-variant;
                clip: true;

                Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.thumbnail;
                    image-fit: cover;
                }
            }

            // Title + subtitle stacked
            VerticalLayout {
                alignment: center;
                spacing: Theme.spacing-xxs;
                horizontal-stretch: 1;

                Text {
                    text: root.title;
                    font-size: Theme.font-body-medium;
                    font-weight: 600;
                    color: Theme.text-primary;
                    overflow: elide;
                    horizontal-alignment: left;
                }

                if root.subtitle != "" : Text {
                    text: root.subtitle;
                    font-size: Theme.font-body-small;
                    color: Theme.text-secondary;
                    overflow: elide;
                    horizontal-alignment: left;
                }
            }
        }

        // == Right: Play/pause button =========================================
        Rectangle {
            width: 40px;
            height: 40px;
            border-radius: 20px;
            background: Theme.accent;
            horizontal-stretch: 0;

            // Play / pause icon (unicode)
            Text {
                text: root.is-playing ? "\u{23F8}" : "\u{25B6}";
                font-size: 18px;
                color: #ffffff;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    // == Progress bar (thin strip across full width) ==========================

    Rectangle {
        y: parent.height - self.height;
        width: parent.width;
        height: 3px;
        background: Theme.progress-background;

        Rectangle {
            width: parent.width * clamp(root.progress, 0.0, 1.0);
            height: parent.height;
            background: Theme.progress-bar;

            animate width {
                duration: Theme.transition-duration;
                easing: linear;
            }
        }
    }

    // == Touch area for whole bar ==============================================

    TouchArea {
        clicked => {
            root.bar-clicked();
        }
    }
}
