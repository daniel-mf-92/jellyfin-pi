// Jellyfin Pi TV App - Content Row Component
// Horizontal scrolling row of MediaCards (Jellyfin Android TV home screen style)

import { Theme, MediaItem } from "theme.slint";
import { MediaCard } from "card.slint";

export component ContentRow inherits VerticalLayout {
    in property <string> title: "";
    in property <[MediaItem]> items: [];
    in property <bool> is-landscape: false;
    in property <bool> is-square: false;
    in property <bool> include-horizontal-overscan: true;
    in-out property <bool> row-focused: false;
    in-out property <int> focused-index: 0;

    callback item-selected(string, string);
    callback item-play-requested(string);

    private property <length> card-width:
        root.is-landscape
            ? Theme.landscape-width
            : (root.is-square ? Theme.square-width : Theme.poster-width);
    // Keep row metrics based on the base card width so max-scroll reflects
    // real content width; apply focus overhang only to the currently focused card.
    private property <length> focus-overhang: root.card-width * (Theme.focus-scale - 1.0) / 2.0;
    private property <length> row-padding:
        root.include-horizontal-overscan ? Theme.overscan-h : 0px;
    private property <length> step-width: root.card-width + Theme.card-gap;
    private property <int> safe-focused-index:
        root.items.length > 0
            ? max(0, min(root.focused-index, root.items.length - 1))
            : 0;
    private property <length> content-width:
        root.items.length > 0
            ? (root.items.length * root.card-width) + ((root.items.length - 1) * Theme.card-gap) + (root.row-padding * 2) + root.focus-overhang
            : root.row-padding * 2;

    spacing: 0px;

    // Row title
    Text {
        text: root.title;
        font-size: Theme.font-title-medium;
        font-weight: 700;
        color: root.row-focused ? Theme.text-primary : Theme.text-secondary;
        horizontal-alignment: left;

        animate color {
            duration: Theme.focus-duration;
        }
    }

    // Spacer between title and cards
    Rectangle {
        height: 8px;
    }

    // Horizontal scrolling card strip
    row-flickable := Flickable {
        width: 100%;
        height: root.is-landscape
            ? Theme.landscape-height + 120px
            : (root.is-square ? Theme.square-height + 120px : Theme.poster-height + 120px);
        viewport-width: root.content-width;
        private property <length> overscan-offset:
            root.include-horizontal-overscan ? Theme.overscan-h : 0px;
        private property <length> max-scroll: max(0px, root.content-width - self.width);
        private property <length> focused-base-start:
            root.row-padding + (root.safe-focused-index * root.step-width);
        private property <length> focused-card-end:
            self.focused-base-start + root.card-width + root.focus-overhang;
        private property <length> raw-scroll-target:
            // Match Jellyfin TV behavior: only scroll once focus reaches the
            // visible right edge, instead of re-centering every move.
            max(0px, self.focused-card-end - self.width);
        private property <length> clamped-scroll-target:
            root.row-focused ? min(self.max-scroll, self.raw-scroll-target) : 0px;

        // Keep Jellyfin TV overscan alignment when rows own horizontal overscan.
        viewport-x: -self.clamped-scroll-target + self.overscan-offset;

        animate viewport-x {
            duration: Theme.transition-duration;
            easing: ease-in-out;
        }

        HorizontalLayout {
            spacing: Theme.card-gap;
            padding-left: root.row-padding;
            padding-right: root.row-padding;

            for item[index] in root.items : MediaCard {
                item: item;
                is-landscape: root.is-landscape;
                is-square: root.is-square;
                focused: root.row-focused && index == root.safe-focused-index;

                selected(id) => {
                    root.item-selected(id, item.item-type);
                }
            }
        }
    }

    // Focus scope for keyboard/gamepad navigation
    FocusScope {
        width: 0px;
        height: 0px;
        enabled: root.row-focused;

        key-pressed(event) => {
            if (event.text == Key.RightArrow || event.text == "Right") {
                if (root.focused-index < root.items.length - 1) {
                    root.focused-index += 1;
                }
                return accept;
            }
            if (event.text == Key.LeftArrow || event.text == "Left") {
                if (root.focused-index > 0) {
                    root.focused-index -= 1;
                }
                return accept;
            }
            if (
                event.text == Key.Return
                || event.text == "Enter"
                || event.text == "Return"
                || event.text == " "
            ) {
                if (root.items.length > 0) {
                    let selected-index = root.safe-focused-index;
                    root.item-selected(
                        root.items[selected-index].id,
                        root.items[selected-index].item-type,
                    );
                }
                return accept;
            }
            return reject;
        }
    }
}
